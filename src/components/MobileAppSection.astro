---
const mobileFeatures = [
  { title: 'Build & Submit Lists', description: 'Create army lists and submit them to your next event without leaving the app' },
  { title: 'Sync Across All Devices', description: 'Your lists stay in sync across web, iOS, and Android — build on desktop, tweak on the go' },
  { title: 'Push Notifications', description: 'Get notified about pairings, results, and tournament updates in real time' },
];
---

<section id="mobile" class="bg-white py-16 sm:py-24 scroll-mt-20 dark:bg-gray-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
      <!-- Phone + Desktop mockup -->
      <div class="mb-12 lg:mb-0 flex justify-center">
        <div class="relative">
          <!-- Desktop screenshot behind -->
          <div class="w-[380px] sm:w-[480px] h-[280px] sm:h-[360px] bg-gray-800 rounded-lg shadow-xl overflow-hidden border border-gray-700 translate-x-6 sm:translate-x-10">
            <div class="h-6 bg-gray-700 flex items-center gap-1.5 px-3">
              <div class="w-2.5 h-2.5 rounded-full bg-red-400"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-400"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-400"></div>
            </div>
            <div class="relative w-full h-[calc(100%-1.5rem)] overflow-hidden">
              <img
                src="/images/battle-builder-desktop.png"
                alt="OWR Battle Builder web app showing army list management with tournament submissions"
                class="absolute bottom-0 right-0 w-[200%] max-w-none"
                loading="lazy"
              />
            </div>
          </div>
          <!-- Phone mockup in front -->
          <div class="absolute -bottom-8 -left-4 sm:-left-8 w-40 h-[320px] sm:w-48 sm:h-[384px] bg-gray-900 rounded-[2rem] sm:rounded-[2.5rem] p-2 sm:p-2.5 shadow-2xl z-10">
            <div class="w-full h-full rounded-[1.5rem] sm:rounded-[2rem] overflow-hidden">
              <img
                src="/images/owr-ios-screenshot.png"
                alt="OWR mobile app showing an army list with Characters and Core Units"
                class="w-full h-full object-cover object-top"
                loading="lazy"
              />
            </div>
          </div>
          <div class="absolute -top-4 -right-4 w-24 h-24 bg-owr-gold/20 rounded-full blur-2xl"></div>
          <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-gray-200 dark:bg-gray-700 rounded-full blur-2xl"></div>
          <!-- Spacer for the phone overflow -->
          <div class="h-16"></div>
        </div>
      </div>

      <!-- Content -->
      <div>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-owr-gold text-gray-900 text-sm font-medium mb-4">
          OWR Pro
        </span>
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-4">
          Take OWR With You
        </h2>
        <p class="text-gray-500 dark:text-gray-400 mb-8">
          Build your army list and submit it to your next event without leaving Battle Builder.
          The OWR mobile app puts everything you need in your pocket — manage lists, check schedules,
          and stay connected with your local scene.
        </p>

        <div class="space-y-6 mb-8">
          {mobileFeatures.map((feature) => (
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-gray-100 dark:bg-gray-800 flex items-center justify-center shrink-0">
                <svg class="h-5 w-5 text-gray-900 dark:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 dark:text-white mb-1">{feature.title}</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400">{feature.description}</p>
              </div>
            </div>
          ))}
        </div>

        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-green-500/20 text-green-600 dark:text-green-400 text-sm font-medium mb-3">
          Launching Late March 2026
        </span>
        <div class="flex flex-wrap gap-4">
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-gray-300 text-gray-500 rounded-lg cursor-not-allowed dark:bg-gray-700 dark:text-gray-500">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09l.01-.01zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z" />
            </svg>
            App Store
          </span>
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-gray-300 text-gray-500 rounded-lg cursor-not-allowed dark:bg-gray-700 dark:text-gray-500">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 010 1.73l-2.808 1.626L15.206 12l2.492-2.491zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z" />
            </svg>
            Google Play
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
