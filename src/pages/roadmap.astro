---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

type RoadmapPhase = 'now' | 'next' | 'later';
type RoadmapCategory = 'Gaming' | 'Community' | 'Hobby';

interface RoadmapItem {
  title: string;
  description: string;
  category: RoadmapCategory;
}

interface RoadmapPhaseGroup {
  phase: RoadmapPhase;
  label: string;
  subtitle: string;
  items: RoadmapItem[];
}

const categoryBadge: Record<RoadmapCategory, string> = {
  Gaming: 'bg-amber-100 text-amber-800 dark:bg-amber-900/50 dark:text-amber-300',
  Community: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/50 dark:text-emerald-300',
  Hobby: 'bg-purple-100 text-purple-800 dark:bg-purple-900/50 dark:text-purple-300',
};

const phaseConfig: Record<RoadmapPhase, { pillClass: string; dotClass: string; lineClass: string; cardOpacity: string }> = {
  now: {
    pillClass: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/50 dark:text-emerald-300',
    dotClass: 'border-emerald-500 dark:border-emerald-400',
    lineClass: 'border-emerald-300 dark:border-emerald-700',
    cardOpacity: '',
  },
  next: {
    pillClass: 'bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300',
    dotClass: 'border-blue-500 dark:border-blue-400',
    lineClass: 'border-blue-300 dark:border-blue-700',
    cardOpacity: '',
  },
  later: {
    pillClass: 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300',
    dotClass: 'border-gray-400 dark:border-gray-500',
    lineClass: 'border-gray-300 dark:border-gray-600 border-dashed',
    cardOpacity: 'opacity-75',
  },
};

const phases: RoadmapPhaseGroup[] = [
  {
    phase: 'now',
    label: 'Now — In Progress',
    subtitle: 'Actively being worked on right now.',
    items: [
      {
        title: 'Battle Hub Scorer',
        description: 'Turn-by-turn game scoring for tournament rounds and ad-hoc games. See both army lists on your phone, track kills, objectives, and soft scores. Save your game history and easily scan and share lists.',
        category: 'Gaming',
      },
      {
        title: 'Team Tournaments',
        description: 'Squad-based tournament format — register as a team, compete together, and earn team rankings. Built for the events that bring your club mates to the table.',
        category: 'Community',
      },
      {
        title: 'Mobile Apps',
        description: 'Native iOS and Android apps with Battle Builder, push notifications, and tournament management on the go. Build lists, check pairings, and stay connected with your local scene.',
        category: 'Gaming',
      },
    ],
  },
  {
    phase: 'next',
    label: 'Next — Coming Soon',
    subtitle: 'Planned and committed for upcoming releases.',
    items: [
      {
        title: 'Clubs',
        description: 'Register your gaming club on OWR. Club profiles, member rosters, club-run events and leagues, and club vs club rankings. Your local scene, organised.',
        category: 'Community',
      },
      {
        title: 'Unit & Item Meta Analysis',
        description: 'Track which units and magic items are winning tournaments. See popularity trends, win rates, and how the meta shifts over time across factions.',
        category: 'Hobby',
      },
      {
        title: 'Internationalisation',
        description: 'Multi-language support for Europe and beyond. Play, organise, and browse OWR in French, German, Spanish, Italian, and more.',
        category: 'Community',
      },
    ],
  },
  {
    phase: 'later',
    label: 'Later — Exploring',
    subtitle: 'Ideas we\'re excited about but haven\'t committed to yet.',
    items: [
      {
        title: 'Online Play Integration',
        description: 'Native integration with online tabletop simulators. Play The Old World remotely with full OWR tournament support — pairings, scoring, and rankings, all connected.',
        category: 'Gaming',
      },
      {
        title: 'ELO Rankings',
        description: 'Matchup-based ranking system that rewards playing stronger opponents. Faction-level ELO stats and head-to-head tracking for a deeper competitive picture.',
        category: 'Gaming',
      },
      {
        title: 'Community Forums',
        description: 'Integrated discussion spaces for local scenes, faction talk, hobby showcasing, and tournament coordination.',
        category: 'Community',
      },
    ],
  },
];
---

<Layout
  title="Roadmap — Old World Rankings"
  description="See what's being built, what's coming next, and where Old World Rankings is headed."
>
  <Nav />

  <main class="pt-24 pb-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4">Roadmap</h1>
        <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
          A look at what we're building, what's coming next, and ideas we're exploring.
        </p>
      </div>

      <!-- Vision block -->
      <div class="rounded-xl bg-gray-50 border border-gray-200 dark:bg-gray-800 dark:border-gray-700 p-6 sm:p-8 mb-16">
        <div class="flex justify-center mb-6">
          <img
            src="/images/owr-pillars.png"
            alt="The three pillars of OWR: Gaming, Community, and Hobby"
            class="max-w-xs w-full"
          />
        </div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">Our Vision</h2>
        <p class="text-gray-600 dark:text-gray-300 mb-3">
          Everything we build at OWR is driven by three pillars: <strong class="text-gray-900 dark:text-white">Community</strong>, <strong class="text-gray-900 dark:text-white">Gaming</strong>, and <strong class="text-gray-900 dark:text-white">Hobby</strong>. These aren't separate tracks — they intersect and feed into each other. <strong class="text-gray-900 dark:text-white">Gaming</strong> and <strong class="text-gray-900 dark:text-white">Hobby</strong> meet in narrative play. <strong class="text-gray-900 dark:text-white">Community</strong> and <strong class="text-gray-900 dark:text-white">Gaming</strong> drive the competitive scene. Together they shape every feature on this roadmap.
        </p>
        <p class="text-gray-600 dark:text-gray-300">
          We're building in the open. This roadmap reflects our current thinking and priorities, shaped by feedback from tournament organisers and players across every region. Things may shift as we learn, but the direction is clear.
        </p>
      </div>

      <!-- Phase groups -->
      <div class="space-y-16">
        {phases.map((group) => {
          const config = phaseConfig[group.phase];
          return (
            <section>
              <!-- Phase header -->
              <div class="mb-6">
                <span class:list={['inline-block rounded-full px-4 py-1.5 text-sm font-semibold mb-2', config.pillClass]}>
                  {group.label}
                </span>
                <p class="text-sm text-gray-500 dark:text-gray-400">{group.subtitle}</p>
              </div>

              <!-- Timeline items -->
              <div>
                {group.items.map((item) => (
                  <article class:list={[
                    'relative pl-8 pb-8 border-l-2 last:pb-0',
                    config.lineClass,
                    config.cardOpacity,
                  ]}>
                    <!-- Timeline dot -->
                    {group.phase === 'now' ? (
                      <div class="absolute -left-[9px] top-0 flex items-center justify-center w-4 h-4">
                        <div class:list={['w-4 h-4 rounded-full bg-white dark:bg-gray-900 border-2', config.dotClass]} />
                        <div class="absolute w-4 h-4 rounded-full border-2 border-emerald-500 dark:border-emerald-400 animate-ping opacity-50" />
                      </div>
                    ) : (
                      <div class:list={['absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-white dark:bg-gray-900 border-2', config.dotClass]} />
                    )}

                    <!-- Card -->
                    <div class="rounded-xl border border-gray-200 bg-white dark:bg-gray-800 dark:border-gray-700 p-5">
                      <div class="flex flex-wrap items-center gap-3 mb-2">
                        <h3 class="text-base font-semibold text-gray-900 dark:text-white">{item.title}</h3>
                        <span class:list={['inline-block rounded-full px-2.5 py-0.5 text-xs font-semibold', categoryBadge[item.category]]}>
                          {item.category}
                        </span>
                      </div>
                      <p class="text-sm text-gray-500 dark:text-gray-400">{item.description}</p>
                    </div>
                  </article>
                ))}
              </div>
            </section>
          );
        })}
      </div>

      <!-- Disclaimer -->
      <p class="mt-16 text-center text-xs text-gray-400 dark:text-gray-500">
        This roadmap reflects our current plans and is subject to change. Features may be added, reprioritised, or removed as we learn from the community.
      </p>
    </div>
  </main>

  <Footer />
</Layout>
