---
const APP_URL = import.meta.env.PUBLIC_APP_URL || 'https://oldworldrankings.com';

const highlights = [
  { text: '13,000+ lists already converted', detail: 'Every army list on OWR is converted automatically — browse, filter, and open any list in Battle Builder.' },
  { text: 'One-click Send to Battle Builder', detail: 'Find a list you like? Send it straight to Battle Builder to tweak, save, and take to your next game.' },
  { text: '100% Old World Builder compatible', detail: 'Download any converted list as an .owb.json file and import it into Old World Builder.' },
  { text: 'New lists converted in real time', detail: 'As tournament lists are submitted, AI Smart Convert processes them instantly — no waiting.' },
];
---

<section id="smart-convert" class="relative py-16 sm:py-24 overflow-hidden scroll-mt-20">
  <!-- Dark background -->
  <div class="absolute inset-0 bg-gray-900">
    <div class="absolute inset-0 opacity-5 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI2MCIgaGVpZ2h0PSI2MCI+CjxyZWN0IHdpZHRoPSI2MCIgaGVpZ2h0PSI2MCIgZmlsbD0iIzAwMCIvPgo8cGF0aCBkPSJNMzYgMzRoLTJ2LTRoLTR2LTJoNHYtNGgydjRoNHYyaC00djR6IiBmaWxsPSIjZmZmIiBmaWxsLW9wYWNpdHk9IjAuNCIvPgo8L3N2Zz4=')]"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
      <!-- Left: Images -->
      <div class="flex flex-col items-center gap-8 mb-12 lg:mb-0 order-2 lg:order-1">
        <div class="relative w-full max-w-lg">
          <img
            src="/images/ai-convert-promo.webp"
            alt="AI Smart Convert transforms plain-text army lists into fully interactive Battle Builder format"
            class="w-full"
            loading="lazy"
          />
          <!-- Decorative glow -->
          <div class="absolute -top-8 -left-8 w-40 h-40 bg-owr-gold/10 rounded-full blur-3xl"></div>
          <div class="absolute -bottom-8 -right-8 w-32 h-32 bg-owr-gold/10 rounded-full blur-2xl"></div>
        </div>
        <!-- In-app actions screenshot (click to enlarge) -->
        <div class="relative w-full max-w-sm">
          <button type="button" class="rounded-xl overflow-hidden shadow-2xl border border-white/10 cursor-zoom-in block w-full" data-lightbox-trigger>
            <img
              src="/images/ai-convert-actions.png"
              alt="Army list details with Pro actions: Copy List, Download .owb.json, and Send to Battle Builder"
              class="w-full"
              loading="lazy"
            />
          </button>
        </div>
      </div>

      <!-- Right: Content -->
      <div class="order-1 lg:order-2">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-owr-gold text-gray-900 text-sm font-medium mb-4">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2l1.09 3.26L16 6l-2.91.74L12 10l-1.09-3.26L8 6l2.91-.74L12 2z"/>
            <path d="M18 12l.6 1.82L20.4 14.4l-1.8.58L18 16.8l-.6-1.82-1.8-.58 1.8-.58L18 12z"/>
            <path d="M7 14l.6 1.82L9.4 16.4l-1.8.58L7 18.8l-.6-1.82-1.8-.58 1.8-.58L7 14z"/>
          </svg>
          AI Smart Convert
        </span>
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">
          Say Goodbye to Text Lists
        </h2>
        <p class="text-white/70 mb-8">
          No more copying text and manually entering lists. AI Smart Convert uses AI to turn every army list on OWR
          into a fully interactive Battle Builder list — ready to tweak, share, and take to the table.
        </p>

        <ul class="space-y-4 mb-8">
          {highlights.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-owr-gold flex-shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <div>
                <span class="text-white font-medium text-sm">{item.text}</span>
                <p class="text-white/50 text-xs mt-0.5">{item.detail}</p>
              </div>
            </li>
          ))}
        </ul>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/pricing"
            class="px-6 py-3 bg-owr-gold text-gray-900 font-semibold rounded-lg hover:bg-owr-gold-dark transition-colors text-center"
          >
            Upgrade to Pro
          </a>
          <a
            href={`${APP_URL}/army-lists`}
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-3 border border-white/30 text-white font-medium rounded-lg hover:bg-white/10 transition-colors text-center"
          >
            Browse Army Lists
          </a>
        </div>
        <p class="text-[11px] text-white/40 mt-3">* AI Smart Convert is a Pro feature.</p>
      </div>
    </div>
  </div>
</section>

<!-- Lightbox overlay -->
<div id="smart-convert-lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm cursor-zoom-out p-4" role="dialog" aria-modal="true">
  <img src="/images/ai-convert-actions.png" alt="Army list details with Pro actions" class="max-w-full max-h-full rounded-xl shadow-2xl" />
</div>

<script>
  const trigger = document.querySelector('[data-lightbox-trigger]');
  const lightbox = document.getElementById('smart-convert-lightbox');

  if (trigger && lightbox) {
    trigger.addEventListener('click', () => {
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
    });

    lightbox.addEventListener('click', () => {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !lightbox.classList.contains('hidden')) {
        lightbox.classList.add('hidden');
        lightbox.classList.remove('flex');
      }
    });
  }
</script>
