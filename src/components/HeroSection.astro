---
/**
 * Branded hero with rotating battle backgrounds, the feature showcase,
 * and global search. The photographic backdrop unifies the whole story.
 * Background images rotate client-side every 8 seconds.
 */
import GlobalSearch from './GlobalSearch';
import FeatureCarousel from './FeatureCarousel.astro';

const heroImages = Array.from({ length: 16 }, (_, i) => `/images/landing/image${i + 1}.jpg`);
---

<section class="relative pt-18 pb-6 sm:pt-28 sm:pb-12">
  <!-- Background with overlay. overflow-hidden lives here, not on the section,
       so the rotating slides and gradients stay clipped to the hero while the
       search dropdown is free to overlay the stats strip below. -->
  <div class="absolute inset-0 overflow-hidden bg-black" id="hero-bg">
    {heroImages.map((src, i) => (
      <div
        class:list={[
          'hero-slide absolute inset-0 transition-opacity duration-1000',
          i === 0 ? 'opacity-50' : 'opacity-0',
        ]}
        data-index={i}
      >
        <img src={src} alt="" class="w-full h-full object-cover" loading={i === 0 ? 'eager' : 'lazy'} />
      </div>
    ))}
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/55 via-black/20 to-black/35"></div>
    <div class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-b from-transparent to-gray-900/80"></div>
  </div>

  <!-- Brand line -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-center lg:justify-start gap-3 sm:gap-4">
      <!-- Hidden on mobile: the nav already shows the logo right above this. -->
      <img
        src="/images/owr_logo_white.png"
        alt="Old World Rankings"
        class="hidden sm:block sm:h-16 sm:w-16 flex-shrink-0"
      />
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white text-balance text-center lg:text-left">
        The Complete Companion to The Old World
      </h1>
    </div>
  </div>

  <!-- Product story over the rotating army photography -->
  <FeatureCarousel />

  <!-- Platform tagline and search -->
  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center mt-2 sm:mt-4">
    <p class="text-sm sm:text-lg lg:text-xl text-white/80 mb-5 sm:mb-6 text-balance">
      Host, Find &amp; Play Events &middot; Create Army Lists &middot; Share Army Galleries &middot; Track Faction Meta &amp; Rankings
    </p>

    <GlobalSearch client:load />
  </div>
</section>

<script>
  // ── Hero image rotation ───────────────────────────────────────────
  const slides = document.querySelectorAll('.hero-slide');
  let current = 0;
  if (slides.length > 1) {
    setInterval(() => {
      slides[current].classList.remove('opacity-50');
      slides[current].classList.add('opacity-0');
      current = (current + 1) % slides.length;
      slides[current].classList.remove('opacity-0');
      slides[current].classList.add('opacity-50');
    }, 8000);
  }
</script>
