---

<div
  id="cookie-banner"
  class="fixed bottom-0 inset-x-0 z-50 hidden"
  role="dialog"
  aria-label="Cookie consent"
>
  <div class="bg-gray-900 border-t border-gray-800 px-4 py-3 sm:px-6">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-sm text-gray-300 text-center sm:text-left">
        We use cookies for analytics to understand how you use our site.
        <a href="/privacy" class="underline text-owr-gold hover:text-owr-gold-dark">Privacy Policy</a>
      </p>
      <div class="flex items-center gap-2 shrink-0">
        <button
          id="cookie-decline"
          class="px-4 py-1.5 text-sm text-gray-400 hover:text-white transition-colors cursor-pointer"
        >
          Decline
        </button>
        <button
          id="cookie-accept"
          class="px-4 py-1.5 text-sm font-semibold bg-owr-gold text-gray-900 rounded-lg hover:bg-owr-gold-dark transition-colors cursor-pointer"
        >
          Accept
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const COOKIE_NAME = 'owr_consent';
  const MAX_AGE = 60 * 60 * 24 * 365; // 1 year

  function getCookieDomain(): string {
    const host = window.location.hostname;
    // .owr-local.site in dev, .oldworldrankings.com in prod
    if (host.endsWith('owr-local.site')) return '.owr-local.site';
    if (host.endsWith('oldworldrankings.com')) return '.oldworldrankings.com';
    return ''; // localhost fallback — no domain attr
  }

  function getConsent(): string | null {
    const match = document.cookie.match(new RegExp(`(?:^|; )${COOKIE_NAME}=([^;]*)`));
    return match ? decodeURIComponent(match[1]) : null;
  }

  function setConsent(value: 'accepted' | 'declined') {
    const domain = getCookieDomain();
    const domainAttr = domain ? `; domain=${domain}` : '';
    const secure = window.location.protocol === 'https:' ? '; Secure' : '';
    document.cookie = `${COOKIE_NAME}=${value}; path=/; max-age=${MAX_AGE}; SameSite=Lax${domainAttr}${secure}`;
  }

  function loadGA() {
    const gaId = document.body.dataset.gaId;
    if (!gaId || document.querySelector(`script[src*="googletagmanager"]`)) return;

    const script = document.createElement('script');
    script.async = true;
    script.src = `https://www.googletagmanager.com/gtag/js?id=${gaId}`;
    document.head.appendChild(script);

    const init = document.createElement('script');
    init.textContent = `
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '${gaId}');
    `;
    document.head.appendChild(init);
  }

  const banner = document.getElementById('cookie-banner');
  const consent = getConsent();

  if (consent === 'accepted') {
    loadGA();
  } else if (!consent) {
    banner?.classList.remove('hidden');
  }

  document.getElementById('cookie-accept')?.addEventListener('click', () => {
    setConsent('accepted');
    loadGA();
    banner?.classList.add('hidden');
  });

  document.getElementById('cookie-decline')?.addEventListener('click', () => {
    setConsent('declined');
    banner?.classList.add('hidden');
  });
</script>
