---
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'https://oldworldrankings.com';
---

<p class="text-center !mt-10">
  <a
    href={`${APP_URL}/host`}
    class="inline-block bg-owr-gold text-gray-900 font-semibold px-6 py-3 rounded-lg hover:bg-owr-gold-dark transition"
  >
    Host a tournament &rarr;
  </a>
</p>
