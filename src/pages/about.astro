---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const APP_URL = import.meta.env.PUBLIC_APP_URL || 'https://oldworldrankings.com';
---

<Layout
  title="About — Old World Rankings"
  description="Meet the creator behind Old World Rankings — the companion platform for Warhammer: The Old World."
>
  <Nav />

  <main class="pt-24 pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Vision -->
      <div class="mb-16">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">About Old World Rankings</h1>
        <div class="space-y-4 text-gray-600 dark:text-gray-400 leading-relaxed">
          <p>
            Old World Rankings started as a simple tournament tracker, but our ambition is much bigger. We're building the central platform for the Warhammer: The Old World community — where competitive players and tournament organisers, hobby enthusiasts and casual gamers all have a home.
          </p>
          <p>
            That means comprehensive meta analysis and <a href={`${APP_URL}/global_rankings`} class="text-gray-900 dark:text-owr-gold font-semibold underline underline-offset-4">global rankings</a> for competitive players. <a href="/tournament-organisers" class="text-gray-900 dark:text-owr-gold font-semibold underline underline-offset-4">Tournament hosting and management tools</a> for organisers. Hobby profiles, <a href={`${APP_URL}/galleries`} class="text-gray-900 dark:text-owr-gold font-semibold underline underline-offset-4">galleries</a>, and social features to connect the community worldwide. We want every part of The Old World experience — from <a href={`${APP_URL}/army-lists`} class="text-gray-900 dark:text-owr-gold font-semibold underline underline-offset-4">list building</a> to tournament day to painting your army — to have a place here.
          </p>
          <p>
            We're building in the open and shaped by feedback from the community. Check out our <a href="/roadmap" class="text-gray-900 dark:text-owr-gold font-semibold underline underline-offset-4">roadmap</a> to see where we're headed.
          </p>
        </div>
      </div>

      <div class="border-t border-gray-200 dark:border-gray-700 pt-12 grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
        <!-- Left: Bio -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">The Creator</h2>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-4">
            I'm one of the hosts of
            <a href="https://oldworldfanatics.com" target="_blank" rel="noopener noreferrer" class="text-gray-700 font-semibold hover:text-gray-900 dark:text-owr-gold dark:hover:text-owr-gold-dark transition-colors underline">Old World Fanatics</a>,
            a podcast dedicated to competitive Warhammer: The Old World.
            Through the podcast and this platform, I'm working to build and support our growing community.
          </p>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
            My first love is Orcs & Goblins — all the way back from 3rd edition. I lived through the Oldhammer days, dropped out in early 6th, and came back for 8th edition just in time for the dark times when Warhammer Fantasy was killed off. That heartbreak is exactly why The Old World means so much to me. Getting to build tools for this community and watch it grow again is something I never take for granted.
          </p>

          <div class="space-y-4">
            <a
              href="https://oldworldfanatics.com"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-gray-700 font-semibold hover:text-gray-900 dark:text-owr-gold dark:hover:text-owr-gold-dark transition-colors"
            >
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
              <span>oldworldfanatics.com</span>
            </a>

            <a
              href="https://www.youtube.com/@oldworldfanatics"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-gray-700 font-semibold hover:text-gray-900 dark:text-owr-gold dark:hover:text-owr-gold-dark transition-colors"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
              </svg>
              <span>YouTube Channel</span>
            </a>

          </div>
        </div>

        <!-- Right: Photo + Name -->
        <div>
          <div class="rounded-lg overflow-hidden bg-gray-800">
            <img
              src="/images/gommo.png"
              alt="Gommo at Warhammer World"
              class="w-full h-[340px] object-cover object-top"
            />
          </div>
          <p class="mt-4 font-handwriting text-4xl text-gray-800 dark:text-owr-gold">gommo</p>
        </div>
      </div>

      <!-- HammerHub -->
      <div class="mt-12 border-t border-gray-200 dark:border-gray-700 pt-12">
        <div class="rounded-xl bg-gradient-to-r from-owr-gold/10 to-owr-gold/5 border border-owr-gold/30 dark:from-owr-gold/15 dark:to-owr-gold/5 dark:border-owr-gold/20 p-6 sm:p-8">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">Powered by HammerHub</h3>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            OWR is powered by <a href="https://hammerhub.com" target="_blank" rel="noopener noreferrer" class="text-gray-900 dark:text-owr-gold font-semibold underline underline-offset-4">HammerHub</a> — a platform we're developing to bring the same tournament, ranking, and community tools to other tabletop wargaming systems. OWR is where it all started, and The Old World community will always be at the heart of what we do.
          </p>
        </div>
      </div>

      <!-- Support -->
      <div class="mt-12 border-t border-gray-200 dark:border-gray-700 pt-12">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Support the Project</h2>
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
          Join us on <a href="https://discord.gg/sdqTWHvYUG" target="_blank" rel="noopener noreferrer" class="text-gray-900 dark:text-owr-gold font-semibold underline underline-offset-4">Discord</a> to share feedback, report issues, or just chat about The Old World. If you'd like to support development, consider upgrading to <a href="/pricing" class="text-gray-900 dark:text-owr-gold font-semibold underline underline-offset-4">OWR Pro</a>.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="https://discord.gg/sdqTWHvYUG"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[#5865F2] text-white font-semibold text-sm hover:bg-[#4752C4] transition-colors"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z" />
            </svg>
            Join our Discord
          </a>
          <a
            href={`${APP_URL}/purchase`}
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-owr-gold text-gray-900 font-semibold text-sm hover:bg-owr-gold-dark transition-colors"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Go Pro
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
