---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import RenegadeArticle from '../../components/insights/RenegadeArticle';
---

<Layout
  title="The Renegade Effect — Old World Rankings"
  description="We dug into 1,097 tournaments to find out if Renegade army lists actually make a difference for Legacy factions. Then we stripped out Vampire Counts — and the real story emerged."
  ogImage="https://www.oldworldrankings.com/images/legacy-player-share.png"
  noindex={true}
>
  <Nav transparent={false} />
  <main class="bg-white dark:bg-[#0a0c10]">
    <RenegadeArticle client:load />
  </main>
</Layout>
