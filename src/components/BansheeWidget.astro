---
const bansheeToken = import.meta.env.PUBLIC_BANSHEE_TOKEN;
---

{bansheeToken && (
  <script is:inline define:vars={{ bansheeToken }}>
    (function(){
      window.banshee = window.banshee || function() {
        (window.banshee.q = window.banshee.q || []).push(arguments);
      };
      var s = document.createElement('script');
      s.src = 'https://scream.banshee.chat/widget/boo.js?v=0';
      s.async = 1;
      document.head.appendChild(s);
    })();
    var initOpts = {
      token: bansheeToken,
      display: 'drawer',
      hideDefaultLauncher: true
    };

    // Sync visitor identity with the session cookie. trusted: true lets the
    // Banshee server swap the device cookie's visitor on a late identify;
    // calling reset on sign-out clears the device cookie so a shared browser
    // doesn't attribute the next visitor's messages to the previous user.
    document.addEventListener('owr:user-loaded', function(e) {
      var user = e.detail;
      if (user && user.id) {
        banshee('identify', {
          userId: String(user.id),
          email: user.email,
          name: user.full_name,
          trusted: true
        });
      } else {
        banshee('reset');
      }
    });

    banshee('init', initOpts);
  </script>
)}
