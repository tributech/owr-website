---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Delete Your Account - Old World Rankings"
  description="Request deletion of your Old World Rankings account and associated data."
>
  <Nav />

  <main class="pt-24 pb-16">
    <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">Delete Your Account</h1>
      <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-2">
        To request deletion of your Old World Rankings account and associated personal data, fill in the form below. This will open an email to our data team pre-filled with your request.
      </p>
      <p class="text-gray-500 dark:text-gray-500 text-sm mb-8">
        We will process your request within 30 days. Tournament results and rankings may be retained in anonymised form as part of the historical competitive record. See our <a href="/privacy" class="text-gray-900 dark:text-owr-gold underline underline-offset-4">Privacy Policy</a> for details.
      </p>

      <form id="delete-form" class="space-y-5">
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Your account email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="you@example.com"
            class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-4 py-2.5 text-gray-900 dark:text-white placeholder-gray-400 focus:border-owr-gold focus:ring-2 focus:ring-owr-gold/30 focus:outline-none"
          />
        </div>

        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Display name on OWR <span class="text-gray-400 font-normal">(optional)</span></label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder="Your display name"
            class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-4 py-2.5 text-gray-900 dark:text-white placeholder-gray-400 focus:border-owr-gold focus:ring-2 focus:ring-owr-gold/30 focus:outline-none"
          />
        </div>

        <button
          type="submit"
          class="w-full rounded-lg bg-red-700 px-4 py-2.5 text-white font-semibold hover:bg-red-800 transition-colors cursor-pointer"
        >
          Request Account Deletion
        </button>
      </form>

      <div id="confirmation" class="hidden">
        <div class="rounded-xl border border-green-300 dark:border-green-700 bg-green-50 dark:bg-green-900/20 p-6">
          <div class="flex items-center gap-2 mb-3">
            <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" /></svg>
            <h2 class="text-lg font-semibold text-green-800 dark:text-green-300">Send your request</h2>
          </div>
          <p class="text-gray-600 dark:text-gray-400 text-sm mb-4">
            Please send an email to the address below with the pre-filled details. We will process your request within 30 days.
          </p>
          <div class="space-y-3 text-sm">
            <div>
              <span class="font-medium text-gray-700 dark:text-gray-300">To:</span>
              <span class="ml-2 text-gray-900 dark:text-white">data@oldworldrankings.com</span>
            </div>
            <div>
              <span class="font-medium text-gray-700 dark:text-gray-300">Subject:</span>
              <span class="ml-2 text-gray-900 dark:text-white">Account Deletion Request</span>
            </div>
            <div>
              <span class="font-medium text-gray-700 dark:text-gray-300">Include:</span>
              <span id="confirm-details" class="ml-2 text-gray-900 dark:text-white"></span>
            </div>
          </div>
          <div class="flex gap-3 mt-5">
            <a id="mailto-link" href="#" class="inline-flex items-center rounded-lg bg-gray-900 dark:bg-owr-gold dark:text-gray-900 px-4 py-2 text-sm font-semibold text-white hover:bg-gray-700 dark:hover:bg-owr-gold-dark transition-colors">
              Open Email Client
            </a>
            <button id="copy-btn" type="button" class="inline-flex items-center rounded-lg border border-gray-300 dark:border-gray-600 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors cursor-pointer">
              Copy Details
            </button>
          </div>
          <p id="copy-feedback" class="text-green-600 dark:text-green-400 text-xs mt-2 hidden">Copied to clipboard!</p>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('delete-form') as HTMLFormElement;
  const confirmation = document.getElementById('confirmation') as HTMLDivElement;
  const confirmDetails = document.getElementById('confirm-details') as HTMLSpanElement;
  const mailtoLink = document.getElementById('mailto-link') as HTMLAnchorElement;
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
  const copyFeedback = document.getElementById('copy-feedback') as HTMLParagraphElement;

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const name = (document.getElementById('name') as HTMLInputElement).value;

    const bodyText = `Hi,\n\nI would like to request the deletion of my Old World Rankings account and associated personal data.\n\nAccount email: ${email}${name ? `\nDisplay name: ${name}` : ''}\n\nThank you.`;

    confirmDetails.textContent = `Account email: ${email}${name ? `, Display name: ${name}` : ''}`;

    const subject = encodeURIComponent('Account Deletion Request');
    const body = encodeURIComponent(bodyText);
    mailtoLink.href = `mailto:data@oldworldrankings.com?subject=${subject}&body=${body}`;

    copyBtn.onclick = async () => {
      const text = `To: data@oldworldrankings.com\nSubject: Account Deletion Request\n\n${bodyText}`;
      await navigator.clipboard.writeText(text);
      copyFeedback.classList.remove('hidden');
      setTimeout(() => copyFeedback.classList.add('hidden'), 2000);
    };

    form.classList.add('hidden');
    confirmation.classList.remove('hidden');
  });
</script>
