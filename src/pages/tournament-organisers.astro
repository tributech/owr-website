---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PricingSection from '../components/PricingSection.astro';

const APP_URL = import.meta.env.PUBLIC_APP_URL || 'https://oldworldrankings.com';

const highlights = [
  { title: 'AI Setup', description: 'Upload your player pack — done in minutes', icon: 'M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z' },
  { title: 'Built-in Payments', description: 'Stripe integration for entry fees', icon: 'M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z' },
  { title: 'Live Battle Board', description: 'Real-time scoring on any device', icon: 'M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5' },
  { title: 'Swiss Pairings', description: 'Automated with manual override', icon: 'M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5' },
];

const lifecycleSteps = [
  { number: '1', label: 'Create' },
  { number: '2', label: 'Setup' },
  { number: '3', label: 'Game Day' },
  { number: '4', label: 'Results' },
];

const extraFeatures = [
  { title: 'Communications Hub', description: 'Email players directly through OWR with proxy replies — your inbox stays private.', icon: 'M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75' },
  { title: 'Staff Management', description: 'Add co-TOs with full access, designate ringers for odd player counts, and manage judges.', icon: 'M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z' },
  { title: 'Documents & Packs', description: 'Upload player packs, house rules, venue maps, and scoring rubrics in one place.', icon: 'M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z' },
  { title: 'Mobile Ready', description: 'Enter results on your phone, manage attendees on a tablet — works on any device.', icon: 'M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3' },
  { title: 'Auto Notifications', description: 'Registration confirmations, list reminders, pairings, and results — all automated.', icon: 'M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0' },
  { title: 'Smart Scheduling', description: 'Auto-schedule rounds with lunch breaks based on start time and round duration.', icon: 'M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z' },
];

---

<Layout
  title="For Tournament Organisers — Old World Rankings"
  description="Everything you need to organise, score, and grow Warhammer: The Old World events — in one place. Free for events up to 20 players."
>
  <Nav />

  <main>
    <!-- ═══════════════════════════════════════════════════════════════
         HERO — Dark bg with crosshatch pattern
         ═══════════════════════════════════════════════════════════════ -->
    <section class="relative pt-32 pb-20 sm:pt-40 sm:pb-28 overflow-hidden">
      <div class="absolute inset-0 bg-gray-900">
        <div class="absolute inset-0 opacity-5 bg-[url('data:image/svg+xml;base64,')]"></div>
      </div>
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-white/10 text-white text-sm font-medium mb-6">
          For Tournament Organisers
        </span>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6 max-w-3xl mx-auto">
          Run Your Tournament Like a Pro
        </h1>
        <p class="text-lg text-gray-400 max-w-2xl mx-auto mb-10">
          Everything you need to organise, score, and grow Warhammer: The Old World events — registration, payments, pairings, live scoring, and results in one place.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
          <a
            href={`${APP_URL}/host`}
            class="px-8 py-3 bg-owr-gold text-gray-900 font-semibold rounded-lg hover:bg-owr-gold-dark transition-colors text-center"
          >
            Start Hosting Free
          </a>
          <a
            href="/pricing"
            class="px-8 py-3 border border-white/30 text-white font-medium rounded-lg hover:bg-white/10 transition-colors text-center"
          >
            See Pricing
          </a>
        </div>

        <!-- Highlight cards -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 max-w-4xl mx-auto">
          {highlights.map((h) => (
            <div class="p-4 rounded-xl bg-white/5 border border-white/10 text-left">
              <svg class="h-6 w-6 text-owr-gold mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={h.icon} />
              </svg>
              <h3 class="text-sm font-semibold text-white mb-1">{h.title}</h3>
              <p class="text-xs text-gray-400">{h.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         LIFECYCLE PROGRESS BAR
         ═══════════════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-20 bg-white dark:bg-gray-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-4">
            From Player Pack to Podium
          </h2>
          <p class="text-gray-500 dark:text-gray-400 max-w-xl mx-auto">
            Here's how OWR takes you through every stage of running a tournament.
          </p>
        </div>

        <!-- Progress steps -->
        <div class="flex items-center justify-between max-w-xs sm:max-w-2xl mx-auto px-2 sm:px-0">
          {lifecycleSteps.map((step, i) => (
            <div class="flex items-center flex-1 last:flex-none">
              <div class="flex flex-col items-center">
                <div class="w-10 h-10 rounded-full bg-owr-gold text-gray-900 font-bold text-sm flex items-center justify-center shrink-0">
                  {step.number}
                </div>
                <span class="text-xs font-medium text-gray-600 dark:text-gray-400 mt-2 whitespace-nowrap">{step.label}</span>
              </div>
              {i < lifecycleSteps.length - 1 && (
                <div class="flex-1 h-0.5 bg-owr-gold/30 mx-2 sm:mx-4 mb-6 min-w-4"></div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         STEP 1: CREATE — gray-50 bg, image RIGHT
         ═══════════════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-gray-50 dark:bg-gray-800 scroll-mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
          <!-- Text -->
          <div class="mb-12 lg:mb-0">
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-owr-gold/10 text-owr-gold-dark dark:text-owr-gold text-sm font-medium mb-4">
              Step 1 — Create
            </span>
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-4">
              Set Up in Minutes, Not Hours
            </h2>
            <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
              Upload your player pack PDF and OWR's AI extracts your tournament details automatically — name, dates, rounds, points limit, entry fee. No more copying and pasting into forms.
            </p>
            <ul class="space-y-3 mb-8">
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="h-5 w-5 text-owr-gold-dark dark:text-owr-gold shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span><strong class="font-semibold">AI-powered setup</strong> — drag and drop your player pack</span>
              </li>
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="h-5 w-5 text-owr-gold-dark dark:text-owr-gold shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span><strong class="font-semibold">Manual fallback</strong> — fine-tune anything the AI misses</span>
              </li>
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="h-5 w-5 text-owr-gold-dark dark:text-owr-gold shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span><strong class="font-semibold">Draft mode</strong> — prepare everything privately before going live</span>
              </li>
            </ul>
          </div>
          <div class="rounded-xl overflow-hidden shadow-lg border border-gray-200 dark:border-gray-700">
            <img src="/images/for-tournament-organisers/for-tos-1.png" alt="AI extracting tournament details from a player pack" class="w-full h-auto" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         STEP 2: REGISTRATION & SETUP — white bg, image LEFT
         ═══════════════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white dark:bg-gray-900 scroll-mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
          <div class="rounded-xl overflow-hidden shadow-lg border border-gray-200 dark:border-gray-700 mb-12 lg:mb-0 order-2 lg:order-1">
            <img src="/images/for-tournament-organisers/for-tos-2.png" alt="Attendee management dashboard" class="w-full h-auto" loading="lazy" />
          </div>
          <!-- Text (RIGHT on desktop) -->
          <div class="order-1 lg:order-2">
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-owr-gold/10 text-owr-gold-dark dark:text-owr-gold text-sm font-medium mb-4">
              Step 2 — Setup
            </span>
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-4">
              Registrations, Payments & Lists — All in One Place
            </h2>
            <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
              Open registrations and let players sign up, pay, and submit their army lists through OWR. No more chasing bank transfers or spreadsheets.
            </p>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="h-5 w-5 text-owr-gold-dark dark:text-owr-gold shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span><strong class="font-semibold">Stripe payments</strong> — collect entry fees with automatic payouts</span>
              </li>
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="h-5 w-5 text-owr-gold-dark dark:text-owr-gold shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span><strong class="font-semibold">Waitlist support</strong> — automatically manage overflow when you hit cap</span>
              </li>
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="h-5 w-5 text-owr-gold-dark dark:text-owr-gold shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span><strong class="font-semibold">Army list collection</strong> — set deadlines and reminders automatically</span>
              </li>
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="h-5 w-5 text-owr-gold-dark dark:text-owr-gold shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span><strong class="font-semibold">Attendee dashboard</strong> — filter by status, check-in, drop, or refund</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         STEP 3: SCORING — gray-50 bg, image RIGHT
         ═══════════════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-gray-50 dark:bg-gray-800 scroll-mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
          <!-- Text -->
          <div class="mb-12 lg:mb-0">
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-owr-gold/10 text-owr-gold-dark dark:text-owr-gold text-sm font-medium mb-4">
              Step 2 — Scoring
            </span>
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-4">
              Flexible Scoring That Fits Your Event
            </h2>
            <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
              Choose from Matched Play, 20-0, or Win-Loss-Draw. Add custom bonus criteria, soft scores for painting and sportsmanship, and favourite opponent voting. Make the scoring system yours.
            </p>
            <div class="grid grid-cols-2 gap-3">
              <div class="p-3 rounded-lg bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
                <p class="text-sm font-semibold text-gray-900 dark:text-white">Matched Play</p>
                <p class="text-xs text-gray-500 dark:text-gray-400">VP differential → Tournament Points</p>
              </div>
              <div class="p-3 rounded-lg bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
                <p class="text-sm font-semibold text-gray-900 dark:text-white">20-0 System</p>
                <p class="text-xs text-gray-500 dark:text-gray-400">Sliding scale scoring</p>
              </div>
              <div class="p-3 rounded-lg bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
                <p class="text-sm font-semibold text-gray-900 dark:text-white">Win-Loss-Draw</p>
                <p class="text-xs text-gray-500 dark:text-gray-400">Simple binary outcomes</p>
              </div>
              <div class="p-3 rounded-lg bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
                <p class="text-sm font-semibold text-gray-900 dark:text-white">Soft Scores</p>
                <p class="text-xs text-gray-500 dark:text-gray-400">Painting, sports & custom</p>
              </div>
            </div>
          </div>
          <div class="rounded-xl overflow-hidden shadow-lg border border-gray-200 dark:border-gray-700">
            <img src="/images/for-tournament-organisers/for-tos-3.png" alt="Scoring configuration with soft scores" class="w-full h-auto" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         TESTIMONIAL 1 — Dark bg with gold accent
         ═══════════════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-gray-900">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="border-l-4 border-owr-gold pl-8 sm:pl-12">
          <svg class="h-10 w-10 text-owr-gold/30 mb-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z" />
          </svg>
          <blockquote class="text-xl sm:text-2xl text-white font-medium leading-relaxed mb-6">
            I used Old World Rankings to run Black Arrow: Beast of Pugno, a 20-player Battle March event with five rounds in a single day as a player-TO. With tight round times, numerous soft scores and votes to manage, having everything run through OWR made a huge difference. I played all five games!
          </blockquote>
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-owr-gold/20 flex items-center justify-center text-owr-gold font-semibold text-sm">
              BA
            </div>
            <div>
              <a href="https://oldworldrankings.com/au/tournaments/black-arrow-beast-of-pugno" target="_blank" rel="noopener noreferrer" class="text-white font-semibold hover:text-owr-gold transition-colors">Black Arrow: Beast of Pugno</a>
              <p class="text-gray-400 text-sm">20-player Battle March event — Player-TO</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         STEP 4: GAME DAY — white bg, image LEFT
         ═══════════════════════════════════════════════════════════════ -->
    <section class="py-16 sm:py-24 bg-white dark:bg-gray-900 scroll-mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
          <div class="rounded-xl overflow-hidden shadow-lg border border-gray-200 dark:border-gray-700 mb-12 lg:mb-0 order-2 lg:order-1">
            <img src="/images/for-tournament-organisers/for-tos-4.png" alt="Live Battle Board with round timer and scenario" class="w-full h-auto" loading="lazy" />
          </div>
          <!-- Text (RIGHT) -->
          <div class="order-1 lg:order-2">
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-owr-gold/10 text-owr-gold-dark dark:text-owr-gold text-sm font-medium mb-4">
              Step 3 — Game Day
            </span>
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-4">
              The Battle Board — Your Command Centre
            </h2>
            <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
              On game day, OWR becomes your live scoring hub. Enter results as matches finish, and standings update instantly. Project the Battle Board onto a venue screen so every player can follow along.
            </p>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="h-5 w-5 text-owr-gold-dark dark:text-owr-gold shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span><strong class="font-semibold">Enter results on any device</strong> — phone, tablet, or laptop</span>
              </li>
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="h-5 w-5 text-owr-gold-dark dark:text-owr-gold shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span><strong class="font-semibold">Swiss pairings</strong> — automated with manual override when needed</span>
              </li>
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="h-5 w-5 text-owr-gold-dark dark:text-owr-gold shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
