---
import CookieConsent from '../components/CookieConsent.astro';
import BansheeWidget from '../components/BansheeWidget.astro';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  ogImage?: string;
}

const gaId = import.meta.env.PUBLIC_GA_ID;
const {
  title,
  description = 'The complete companion for Warhammer: The Old World. Rankings, tournaments, army lists, galleries and more.',
  noindex = false,
  ogImage,
} = Astro.props;

const DEFAULT_OG_IMAGE = '/images/owr-og-default.jpg';
const ogImagePath = ogImage ?? DEFAULT_OG_IMAGE;
const ogImageUrl = ogImagePath.startsWith('http')
  ? ogImagePath
  : new URL(ogImagePath, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <!-- Prevent FOUC: apply theme before paint -->
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('owr-theme-preference');
        if (!theme) theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.classList.add(theme);
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    {!ogImage && (
      <>
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="675" />
        <meta property="og:image:alt" content="Old World Rankings" />
      </>
    )}
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Permanent+Marker&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!-- Global CSS -->
    <style is:global>
      @import '../styles/global.css';
    </style>


  </head>
  <body
    class="min-h-screen overflow-x-clip bg-white text-gray-900 dark:bg-gray-900 dark:text-gray-100"
    data-ga-id={gaId || undefined}
  >
    <slot />
    <CookieConsent />
    <BansheeWidget />
  </body>
</html>
