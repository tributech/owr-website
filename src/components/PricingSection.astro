---
const APP_URL = import.meta.env.PUBLIC_APP_URL || 'https://oldworldrankings.com';

const freeFeatures = [
  { label: 'Tournament hosting', isNew: true },
  { label: 'Battle Builder', isNew: true },
  { label: 'View rankings & stats' },
  { label: 'Browse army lists' },
  { label: 'Register for tournaments' },
  { label: 'Play in tournaments' },
  { label: 'Faction statistics' },
  { label: 'Faction leaderboards' },
  { label: 'Community features' },
];

const proFeatures = [
  { label: 'Army Builder Sync', isHot: true },
  { label: 'Early Army List Access', isHot: true },
  { label: 'Battle Hub Scorer', isHot: true },
  { label: 'Tournament Pack AI Assist', isHot: true },
  { label: 'Private Tournaments' },
  { label: 'Advanced Stats' },
  { label: 'Notifications' },
  { label: 'Ad-Free' },
  { label: 'Priority Support' },
];
---

<section id="pricing" class="relative py-16 sm:py-24 overflow-hidden scroll-mt-20">
  <!-- Dark background with crosshatch pattern -->
  <div class="absolute inset-0 bg-gray-900">
    <div class="absolute inset-0 opacity-5 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0MCIgaGVpZ2h0PSI0MCI+CjxyZWN0IHdpZHRoPSI0MCIgaGVpZ2h0PSI0MCIgZmlsbD0iIzAwMCIvPgo8cGF0aCBkPSJNMCAwTDQwIDQwTTQwIDBMMCA0MCIgc3Ryb2tlPSIjZmZmIiBzdHJva2Utd2lkdGg9IjEiLz4KPC9zdmc+')]"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-white/10 text-white text-sm font-medium mb-4">
        &#10024; Unlock More
      </span>
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">Take Your Game Further</h2>
      <p class="text-white/70 max-w-2xl mx-auto">
        Everything you need to compete. Upgrade to Pro to unlock the full experience.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      <!-- Free tier -->
      <div class="p-6 sm:p-8 rounded-xl bg-white/5 backdrop-blur border border-white/10 flex flex-col">
        <h3 class="text-xl font-bold text-white mb-2">OWR Free</h3>
        <p class="text-white/60 mb-6">Everything you need to compete</p>
        <p class="text-3xl font-bold text-white mb-6">
          $0<span class="text-lg font-normal text-white/60" data-free-suffix> USD/month</span>
        </p>
        <ul class="space-y-3 flex-grow">
          {freeFeatures.map((feature) => (
            <li class="flex items-center gap-3 text-white/90">
              <svg class="h-5 w-5 text-white/60 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>{feature.label}</span>
              {feature.isNew && <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-green-500 text-white font-semibold">NEW</span>}
            </li>
          ))}
        </ul>
        <a
          href={`${APP_URL}/register`}
          class="block w-full py-3 text-center bg-transparent border border-white/30 text-white font-medium rounded-lg hover:bg-white/10 transition-colors mt-8"
        >
          Get Started Free
        </a>
      </div>

      <!-- Pro tier -->
      <div class="p-6 sm:p-8 rounded-xl bg-white border border-gray-200 dark:bg-gray-800 dark:border-gray-700 relative flex flex-col">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2">
          <span class="px-3 py-1 rounded-full bg-owr-gold text-gray-900 text-xs font-semibold">
            RECOMMENDED
          </span>
        </div>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">OWR Pro</h3>
        <p class="text-gray-500 dark:text-gray-400 mb-6">For tournament organizers &amp; power users</p>
        <p class="text-3xl font-bold text-gray-900 dark:text-white mb-1">
          <span data-pro-price>$5.83</span><span class="text-lg font-normal text-gray-500 dark:text-gray-400" data-pro-suffix> USD/month</span>
        </p>
        <p class="text-xs text-gray-400 dark:text-gray-500 mb-4">* Billed yearly (2 months free). <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full bg-green-100 text-green-800 text-[10px] font-medium">Introductory pricing</span></p>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Everything in Free, plus:</p>
        <ul class="space-y-3 flex-grow">
          {proFeatures.map((feature) => (
            <li class="flex items-center gap-3 text-gray-900 dark:text-white">
              <svg class="h-5 w-5 text-gray-900 dark:text-white shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>{feature.label}</span>
              {feature.isHot && <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-owr-gold text-gray-900 font-semibold">HOT</span>}
            </li>
          ))}
          <li class="flex items-center gap-3 text-gray-900 dark:text-white pt-2 border-t border-gray-200 dark:border-gray-700">
            <svg class="h-5 w-5 text-owr-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="font-semibold">Support the continued development of Old World Rankings</span>
          </li>
        </ul>
        <a
          href={`${APP_URL}/purchase`}
          class="block w-full py-3 text-center bg-owr-gold text-gray-900 font-semibold rounded-lg hover:bg-owr-gold-dark transition-colors mt-8"
        >
          Upgrade to Pro
        </a>
      </div>
    </div>

    <p class="text-center mt-8 text-white/60 text-sm">
      <a href="/pricing" class="text-white underline underline-offset-4 hover:text-white/80">
        View full pricing details
      </a>
    </p>
  </div>
</section>

<script>
  import { detectCurrency, priceForCurrency } from '../lib/pricing';

  function updatePricing() {
    const user = window.__owrUser;
    const currency = detectCurrency(user?.region_slug);
    const price = priceForCurrency(currency);

    const section = document.getElementById('pricing');
    if (!section) return;

    const priceEl = section.querySelector('[data-pro-price]');
    const suffixEl = section.querySelector('[data-pro-suffix]');
    const freeSuffixEl = section.querySelector('[data-free-suffix]');
    if (priceEl) priceEl.textContent = price.display;
    if (suffixEl) suffixEl.textContent = ` ${price.suffix}`;
    if (freeSuffixEl) freeSuffixEl.textContent = ` ${price.suffix}`;
  }

  document.addEventListener('owr:user-loaded', () => updatePricing());
  if (window.__owrUser !== undefined) updatePricing();
</script>
