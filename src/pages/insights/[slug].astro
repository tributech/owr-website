---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getClient, ogImageUrl } from '../../lib/contentful';
import { renderRichText } from '../../lib/rich-text';
import type { InsightArticleSkeleton, InsightArticleEntry } from '../../lib/contentful-types';
import type { Document } from '@contentful/rich-text-types';

// Custom article components - Astro needs static imports for client:load hydration.
// Add new custom articles here with an import + slug match below.
import RenegadeArticle from '../../components/insights/RenegadeArticle';

export async function getStaticPaths() {
  const client = getClient();
  if (!client) return [];

  let articles: InsightArticleEntry[] = [];
  try {
    const response = await client.getEntries<InsightArticleSkeleton>({
      content_type: 'insightArticle',
      include: 2,
    });
    articles = response.items;
  } catch (e) {
    console.error('insightArticle getStaticPaths error:', e);
    return [];
  }

  return articles.map((article) => ({
    params: { slug: article.fields.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const isCustom = article.fields.customPage === true;
const slug = article.fields.slug;

// Resolve author
const authorEntry = article.fields.authorRef && 'fields' in article.fields.authorRef
  ? article.fields.authorRef : null;
const authorAvatar = authorEntry?.fields?.avatar && 'fields' in authorEntry.fields.avatar
  ? authorEntry.fields.avatar.fields?.file?.url : null;
const authorProfileUrl = authorEntry?.fields?.profileUrl;

// Resolve featured image for OG (resized + re-encoded to keep social previews small)
const ogImage = article.fields.featuredImage && 'fields' in article.fields.featuredImage
  ? ogImageUrl(article.fields.featuredImage.fields?.file?.url)
  : undefined;

// Render body for standard articles
const bodyHtml = !isCustom && article.fields.body
  ? renderRichText(article.fields.body as Document)
  : '';

const date = new Date(article.fields.publishDate).toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric',
});
const tags = article.fields.tags || [];
const APP_URL = import.meta.env.PUBLIC_APP_URL || 'https://oldworldrankings.com';

// Social share row (matches the custom Renegade article's header)
const shareUrl = `https://www.oldworldrankings.com/insights/${slug}/`;
const shareTitle = article.fields.title;
const shareText = `${shareTitle} - Old World Rankings`;
const shareLinks = [
  { label: 'Bluesky', href: `https://bsky.app/intent/compose?text=${encodeURIComponent(`${shareText}\n${shareUrl}`)}`, icon: 'M5.202 2.857C7.954 4.922 10.913 9.11 12 11.358c1.087-2.247 4.046-6.436 6.798-8.501C20.783 1.366 24 .213 24 3.883c0 .732-.42 6.156-.667 7.037-.856 3.061-3.978 3.842-6.755 3.37 4.854.826 6.089 3.562 3.422 6.299-5.065 5.196-7.28-1.304-7.847-2.97-.104-.305-.152-.448-.153-.327 0-.121-.05.022-.153.327-.568 1.666-2.782 8.166-7.847 2.97-2.667-2.737-1.432-5.473 3.422-6.3-2.777.473-5.899-.308-6.755-3.369C.42 10.04 0 4.615 0 3.883c0-3.67 3.217-2.517 5.202-1.026' },
  { label: 'Facebook', href: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`, icon: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z' },
  { label: 'Reddit', href: `https://reddit.com/submit?url=${encodeURIComponent(shareUrl)}&title=${encodeURIComponent(shareTitle)}`, icon: 'M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 0-.463.327.327 0 0 0-.462 0c-.545.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.231-.094z' },
];
const discordIcon = 'M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z';
const discordCopyText = `${shareText}\n${shareUrl}`;
---

<Layout
  title={`${article.fields.title} - Old World Rankings`}
  description={article.fields.description}
  ogImage={ogImage}
>
  <Nav transparent={false} />

  <main class="bg-white dark:bg-[#0a0c10]">
    {/* Custom pages - add new slug matches here */}
    {isCustom && slug === 'renegade-effect' && <RenegadeArticle client:load />}

    {!isCustom && (
      <article class="pt-24 pb-16">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
          <header class="mb-10">
            <div class="flex items-start justify-between gap-4 mb-4">
              <div class="flex items-center gap-2.5 text-sm text-gray-500 dark:text-gray-400">
                {authorEntry ? (
                  <>
                    <a
                      href={authorProfileUrl ? `${APP_URL}${authorProfileUrl}` : undefined}
                      class="flex items-center gap-2 hover:opacity-80 transition-opacity"
                    >
                      {authorAvatar ? (
                        <img src={`https:${authorAvatar}`} alt={authorEntry.fields.name}
                          class="w-7 h-7 rounded-full ring-1 ring-owr-gold/30" />
                      ) : (
                        <div class="w-7 h-7 rounded-full bg-gray-200 dark:bg-gray-800 flex items-center justify-center">
                          <span class="text-xs font-bold text-gray-500 dark:text-gray-400">{authorEntry.fields.name.charAt(0)}</span>
                        </div>
                      )}
                      <span>{authorEntry.fields.nickname ? `@${authorEntry.fields.nickname}` : authorEntry.fields.name}</span>
                    </a>
                    <span class="text-gray-300 dark:text-gray-600">&middot;</span>
                  </>
                ) : null}
                <time>{date}</time>
              </div>
              <div class="flex items-center gap-2">
                {shareLinks.map((s) => (
                  <a href={s.href} target="_blank" rel="noopener noreferrer" title={`Share on ${s.label}`}
                    class="w-8 h-8 rounded-lg bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 flex items-center justify-center hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors cursor-pointer">
                    <svg class="w-4 h-4 text-gray-600 dark:text-gray-400" viewBox="0 0 24 24" fill="currentColor"><path d={s.icon} /></svg>
                  </a>
                ))}
                <button type="button" data-copy={discordCopyText} title="Copy for Discord"
                  class="copy-btn w-8 h-8 rounded-lg bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 flex items-center justify-center hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors cursor-pointer">
                  <svg class="copy-icon w-4 h-4 text-gray-600 dark:text-gray-400" viewBox="0 0 24 24" fill="currentColor"><path d={discordIcon} /></svg>
                  <svg class="check-icon hidden w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                </button>
                <button type="button" data-copy={shareUrl} title="Copy link"
                  class="copy-btn w-8 h-8 rounded-lg bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 flex items-center justify-center hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors cursor-pointer">
                  <svg class="copy-icon w-4 h-4 text-gray-600 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" /></svg>
                  <svg class="check-icon hidden w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                </button>
              </div>
            </div>
            <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4">
              {article.fields.title}
            </h1>
            <p class="text-lg text-gray-600 dark:text-gray-400 mb-6">
              {article.fields.description}
            </p>
            {tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {tags.map((tag: string) => (
                  <span class="text-xs px-2.5 py-1 rounded-full bg-gray-100 dark:bg-white/[0.06] text-gray-600 dark:text-gray-400">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </header>

          <div class="prose prose-gray dark:prose-invert max-w-none" set:html={bodyHtml} />
        </div>
      </article>
    )}

  </main>
  <Footer />
</Layout>

<script>
  // Copy-to-clipboard for the share row's copy buttons (Discord text + link).
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy;
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        const copyIcon = btn.querySelector('.copy-icon');
        const checkIcon = btn.querySelector('.check-icon');
        copyIcon?.classList.add('hidden');
        checkIcon?.classList.remove('hidden');
        setTimeout(() => {
          copyIcon?.classList.remove('hidden');
          checkIcon?.classList.add('hidden');
        }, 1500);
      } catch {
        // Clipboard API unavailable (e.g. insecure context) - silently no-op.
      }
    });
  });
</script>
