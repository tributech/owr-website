---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import HeroSection from '../components/HeroSection.astro';
import StatsBar from '../components/StatsBar.astro';
import RegionsSection from '../components/RegionsSection.astro';
import RankingsSection from '../components/RankingsSection.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import ArmyBuilderSection from '../components/ArmyBuilderSection.astro';
import AiSmartConvertSection from '../components/AiSmartConvertSection.astro';
import TournamentHostingSection from '../components/TournamentHostingSection.astro';
import PricingSection from '../components/PricingSection.astro';
import MobileAppSection from '../components/MobileAppSection.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Old World Rankings — The Complete Companion to The Old World">
  <Nav transparent={true} />

  <!-- Hero with dark battle background -->
  <HeroSection />

  <!-- AI Smart Convert teaser banner -->
  <a href="#smart-convert" class="block bg-owr-gold hover:bg-owr-gold-dark transition-colors">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2.5 flex items-center justify-center gap-2 text-sm font-medium text-gray-900">
      <span><strong>NEW</strong> — Wave goodbye to text lists 👋 AI Smart Convert is here</span>
      <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </div>
  </a>

  <!-- Stats Bar -->
  <StatsBar />

  <!-- Regions -->
  <RegionsSection />

  <!-- Rankings -->
  <RankingsSection />

  <!-- Features -->
  <FeaturesSection />

  <!-- AI Smart Convert -->
  <AiSmartConvertSection />

  <!-- Battle Builder -->
  <ArmyBuilderSection />

  <!-- Tournament Hosting -->
  <TournamentHostingSection />

  <!-- Pricing -->
  <PricingSection />

  <!-- Mobile App -->
  <MobileAppSection />

  <!-- Footer -->
  <Footer />
</Layout>
