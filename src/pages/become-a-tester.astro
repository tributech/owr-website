---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import MobileTesterPreview from '../components/MobileTesterPreview.tsx';
---

<Layout
  title="Become a Mobile Tester - Old World Rankings"
  description="Help us shape the OWR mobile apps for iOS and Android."
  noindex={true}
>
  <Nav />

  <main class="pt-24 pb-16 bg-white dark:bg-gray-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Hero -->
      <div class="lg:grid lg:grid-cols-2 lg:gap-12 items-center mb-16">
        <div>
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-owr-gold text-gray-900 text-sm font-medium mb-4">
            Closed Beta
          </span>
          <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4">
            Help us test the OWR mobile apps
          </h1>
          <p class="text-gray-500 dark:text-gray-400 text-lg mb-6">
            We're recruiting a small group of testers to put the iOS and Android apps through their paces
            ahead of public release. If you play in tournaments, run events, or just want to be part of
            shaping the apps, we'd love to have you.
          </p>
          <div class="space-y-3">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-owr-gold mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-gray-700 dark:text-gray-300"><strong>Team tournaments</strong>: newest feature, lots to verify across platforms</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-owr-gold mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-gray-700 dark:text-gray-300"><strong>Army list builder</strong>: build, sync, and submit lists from your phone</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-owr-gold mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-gray-700 dark:text-gray-300"><strong>Live tournament flow</strong>: pairings, results, push notifications</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-owr-gold mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-gray-700 dark:text-gray-300"><strong>Cross-device sync</strong>: web, iOS, and Android all in step</p>
            </div>
          </div>
        </div>

        <!-- Device mockups -->
        <div class="mt-12 lg:mt-0">
          <MobileTesterPreview />
        </div>
      </div>

      <!-- What testing looks like -->
      <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 p-6 sm:p-8 mb-8">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">How the beta works</h2>
        <ul class="space-y-2 text-gray-600 dark:text-gray-400">
          <li>You'll get a TestFlight invite (iOS) or a Google Play closed-track invite (Android), or both.</li>
          <li>You'll be added to a private channel on the OWR Discord to submit and discuss feedback with the team and other testers.</li>
          <li><strong class="text-gray-900 dark:text-white">Free OWR Pro for the duration of the beta</strong> if you don't already have it, so you can use the full Battle Builder feature set across web and mobile.</li>
          <li>We'll push new builds roughly weekly through to public launch.</li>
          <li>No NDA, no commitment, drop out any time.</li>
        </ul>
      </div>

      <!-- What you'll actually do -->
      <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 p-6 sm:p-8 mb-12">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">What you'll actually do</h2>
        <ul class="space-y-3 text-gray-600 dark:text-gray-400">
          <li>
            <strong class="text-gray-900 dark:text-white">Register for test events.</strong>
            We'll run a mix of singles, doubles, and team tournaments. You'll sign up through the
            app the same way you would for a real event.
          </li>
          <li>
            <strong class="text-gray-900 dark:text-white">Play through tournaments end to end.</strong>
            Each test tournament runs over a few days from registration to final standings, so we
            can shake out the full lifecycle: list submission, pairings, scoring, and results.
          </li>
          <li>
            <strong class="text-gray-900 dark:text-white">Log realistic scores.</strong>
            Treat it like a real game. The more believable the data, the more useful the test.
          </li>
          <li>
            <strong class="text-gray-900 dark:text-white">Confirm your opponent's scores.</strong>
            If your opponent submits the round first, jump in and confirm (or dispute) the result
            from your side. This is one of the flows we most need eyes on.
          </li>
          <li>
            <strong class="text-gray-900 dark:text-white">Build and sync lists in Battle Builder.</strong>
            Use Battle Builder on the web to assemble lists, then check they sync cleanly to the
            mobile app (and vice versa). Submit them to the test events from whichever device
            feels natural.
          </li>
          <li>
            <strong class="text-gray-900 dark:text-white">Don't worry about your profile.</strong>
            Test events may briefly appear on your public OWR profile while the beta is running.
            We'll wipe them all before launch so nothing test-related ends up on your record.
          </li>
        </ul>
      </div>

      <!-- Form -->
      <div class="max-w-2xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Sign me up</h2>
        <p class="text-gray-500 dark:text-gray-400 mb-8">
          We need the email tied to your <strong>Apple ID</strong> (for TestFlight) or <strong>Google account</strong>
          (for Play Store closed track). That's how the invites get delivered. Fill in whichever platforms you want to test.
        </p>

        <form
          name="mobile-testers"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/become-a-tester-thanks/"
          class="space-y-6"
        >
          <input type="hidden" name="form-name" value="mobile-testers" />
          <p class="hidden">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              Your name <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="block w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-4 py-2.5 text-gray-900 dark:text-white shadow-sm focus:border-owr-gold focus:ring-1 focus:ring-owr-gold focus:outline-none"
            />
          </div>

          <div>
            <label for="contact-email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              Best contact email <span class="text-red-500">*</span>
            </label>
            <input
              type="email"
              id="contact-email"
              name="contact-email"
              required
              class="block w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-4 py-2.5 text-gray-900 dark:text-white shadow-sm focus:border-owr-gold focus:ring-1 focus:ring-owr-gold focus:outline-none"
            />
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Where we'll send updates and instructions.</p>
          </div>

          <fieldset>
            <legend class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              Which platforms do you want to test? <span class="text-red-500">*</span>
            </legend>
            <div class="space-y-2">
              <label class="flex items-center gap-2">
                <input type="checkbox" name="platforms[]" value="ios" class="rounded border-gray-300 text-owr-gold focus:ring-owr-gold" />
                <span class="text-gray-700 dark:text-gray-300">iOS (iPhone / iPad)</span>
              </label>
              <label class="flex items-center gap-2">
                <input type="checkbox" name="platforms[]" value="android" class="rounded border-gray-300 text-owr-gold focus:ring-owr-gold" />
                <span class="text-gray-700 dark:text-gray-300">Android</span>
              </label>
            </div>
          </fieldset>

          <div>
            <label for="apple-id-email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              Apple ID email
            </label>
            <input
              type="email"
              id="apple-id-email"
              name="apple-id-email"
              class="block w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-4 py-2.5 text-gray-900 dark:text-white shadow-sm focus:border-owr-gold focus:ring-1 focus:ring-owr-gold focus:outline-none"
            />
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Required if you ticked iOS. TestFlight invites go here.</p>
          </div>

          <div>
            <label for="google-account-email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              Google account email
            </label>
            <input
              type="email"
              id="google-account-email"
              name="google-account-email"
              class="block w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-4 py-2.5 text-gray-900 dark:text-white shadow-sm focus:border-owr-gold focus:ring-1 focus:ring-owr-gold focus:outline-none"
            />
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Required if you ticked Android. Play Store closed-track invites go here.</p>
          </div>

          <div>
            <label for="discord" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              Discord username
            </label>
            <input
              type="text"
              id="discord"
              name="discord"
              placeholder="e.g. yourname or yourname#1234"
              class="block w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-4 py-2.5 text-gray-900 dark:text-white shadow-sm focus:border-owr-gold focus:ring-1 focus:ring-owr-gold focus:outline-none"
            />
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">So we can add you to the private testers channel on the OWR Discord. If you're not on it yet, we'll send the invite.</p>
          </div>

          <div>
            <label for="device" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              Device(s) you'd test on
            </label>
            <input
              type="text"
              id="device"
              name="device"
              placeholder="e.g. iPhone 15 Pro on iOS 18.2, Pixel 8 on Android 15"
              class="block w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-4 py-2.5 text-gray-900 dark:text-white shadow-sm focus:border-owr-gold focus:ring-1 focus:ring-owr-gold focus:outline-none"
            />
          </div>

          <div>
            <label for="region" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              Country / region
            </label>
            <input
              type="text"
              id="region"
              name="region"
              placeholder="e.g. Australia, UK, US East"
              class="block w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-4 py-2.5 text-gray-900 dark:text-white shadow-sm focus:border-owr-gold focus:ring-1 focus:ring-owr-gold focus:outline-none"
            />
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Helps us match testers to local tournaments.</p>
          </div>

          <div>
            <label for="notes" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              Anything else we should know?
            </label>
            <textarea
              id="notes"
              name="notes"
              rows="4"
              class="block w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-4 py-2.5 text-gray-900 dark:text-white shadow-sm focus:border-owr-gold focus:ring-1 focus:ring-owr-gold focus:outline-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-owr-gold text-gray-900 font-semibold hover:bg-owr-gold/90 focus:outline-none focus:ring-2 focus:ring-owr-gold focus:ring-offset-2 transition-colors"
          >
            Sign me up
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </button>
        </form>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

