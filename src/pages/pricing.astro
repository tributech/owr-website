---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const APP_URL = import.meta.env.PUBLIC_APP_URL || 'https://oldworldrankings.com';

const freeFeatures = [
  { label: 'Tournament hosting', isNew: true },
  { label: 'Battle Builder', isNew: true },
  { label: 'View rankings & stats' },
  { label: 'Browse army lists' },
  { label: 'Register for tournaments' },
  { label: 'Play in tournaments' },
  { label: 'Faction statistics' },
  { label: 'Faction leaderboards' },
  { label: 'Community features' },
];

const proFeatures = [
  { label: 'Everything in Free' },
  { label: 'Army Builder Sync', isHot: true },
  { label: 'Early Army List Access', isHot: true },
  { label: 'Battle Hub Scorer', isHot: true },
  { label: 'Tournament Pack AI Assist', isHot: true },
  { label: 'Private Tournaments' },
  { label: 'Presale Dates' },
  { label: 'Advanced Army Filters' },
  { label: 'Advanced Stats' },
  { label: 'Profile Customization' },
  { label: 'Notifications' },
  { label: 'Ad-Free' },
  { label: 'Bulk Army List Download' },
  { label: 'Tournament Comms' },
  { label: 'Priority Support' },
];

---

<Layout
  title="Pricing — Old World Rankings"
  description="Everything you need to compete. Upgrade to Pro to unlock the full experience."
>
  <Nav />

  <main class="pt-24 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-16">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4">
          Simple, Transparent Pricing
        </h1>
        <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
          Everything you need to compete. Upgrade to Pro to unlock the full experience.
        </p>
      </div>

      <!-- Pricing cards -->
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto mb-20">
        <!-- Free -->
        <div class="p-8 rounded-2xl border border-gray-200 bg-white dark:bg-gray-800 dark:border-gray-700 flex flex-col">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Free</h2>
          <p class="text-gray-500 dark:text-gray-400 mb-6">Everything you need to compete</p>
          <p class="text-4xl font-bold text-gray-900 dark:text-white mb-8">
            $0<span class="text-lg font-normal text-gray-500 dark:text-gray-400" data-free-suffix> USD/month</span>
          </p>
          <ul class="space-y-4 flex-grow">
            {freeFeatures.map((f) => (
              <li class="flex items-center gap-3 text-gray-700 dark:text-gray-300">
                <svg class="h-5 w-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {f.label}
                {f.isNew && <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-green-500 text-white font-semibold">NEW</span>}
              </li>
            ))}
          </ul>
          <a
            href={`${APP_URL}/register`}
            class="block w-full py-3 text-center border border-gray-300 text-gray-900 font-medium rounded-lg hover:bg-gray-50 dark:border-gray-600 dark:text-white dark:hover:bg-gray-700 transition-colors mt-8"
          >
            Get Started Free
          </a>
        </div>

        <!-- Pro -->
        <div class="p-8 rounded-2xl border-2 border-owr-gold bg-white dark:bg-gray-800 relative flex flex-col">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="px-4 py-1 rounded-full bg-owr-gold text-gray-900 text-sm font-semibold">
              RECOMMENDED
            </span>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Pro</h2>
          <p class="text-gray-500 dark:text-gray-400 mb-6">For organizers &amp; power users</p>
          <p class="text-4xl font-bold text-gray-900 dark:text-white mb-1">
            <span data-pro-price>$5.83</span><span class="text-lg font-normal text-gray-500 dark:text-gray-400" data-pro-suffix> USD/month</span>
          </p>
          <p class="text-xs text-gray-400 dark:text-gray-500 mb-6">* Billed yearly (2 months free). <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full bg-green-100 text-green-800 text-[10px] font-medium">Introductory pricing</span></p>
          <ul class="space-y-4 flex-grow">
            {proFeatures.map((f) => (
              <li class="flex items-center gap-3 text-gray-700 dark:text-gray-300">
                <svg class="h-5 w-5 text-owr-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>{f.label}</span>
                {f.isHot && <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-owr-gold text-gray-900 font-semibold">HOT</span>}
              </li>
            ))}
            <li class="flex items-center gap-3 text-gray-700 dark:text-gray-300 pt-3 border-t border-gray-200 dark:border-gray-700">
              <svg class="h-5 w-5 text-owr-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="font-semibold text-gray-900 dark:text-white">Support the continued development of Old World Rankings</span>
            </li>
          </ul>
          <a
            href={`${APP_URL}/purchase`}
            class="block w-full py-3 text-center bg-gray-900 text-white font-medium rounded-lg hover:bg-gray-800 transition-colors mt-8"
          >
            Upgrade to Pro
          </a>
        </div>
      </div>

    </div>
  </main>

  <Footer />

  <script>
    import { detectCurrency, priceForCurrency } from '../lib/pricing';

    function updatePricing() {
      const user = window.__owrUser;
      const currency = detectCurrency(user?.region_slug);
      const price = priceForCurrency(currency);

      const priceEl = document.querySelector('[data-pro-price]');
      const suffixEl = document.querySelector('[data-pro-suffix]');
      const freeSuffixEl = document.querySelector('[data-free-suffix]');
      if (priceEl) priceEl.textContent = price.display;
      if (suffixEl) suffixEl.textContent = ` ${price.suffix}`;
      if (freeSuffixEl) freeSuffixEl.textContent = ` ${price.suffix}`;
    }

    document.addEventListener('owr:user-loaded', () => updatePricing());
    if (window.__owrUser !== undefined) updatePricing();
  </script>
</Layout>
