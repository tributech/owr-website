---
import Layout from '../layouts/Layout.astro';
import { Trophy, BarChart, CalendarArrowUp, ScrollText, Image, Hammer, ChevronDown, X as CloseIcon, ZoomIn, MessageCircleQuestion, Mail, ChevronLeft, ChevronRight } from '@lucide/astro';

const APP_URL = import.meta.env.PUBLIC_APP_URL || 'https://oldworldrankings.com';

const slides = [
  { id: 'cover', label: 'Cover' },
  { id: 'platform', label: 'Platform' },
  { id: 'traffic', label: 'Traffic' },
  { id: 'audience', label: 'Audience' },
  { id: 'why-now', label: 'Why Now' },
  { id: 'placements', label: 'Placements' },
  { id: 'pricing', label: 'Pricing' },
  { id: 'close', label: 'Next Step' },
];

const growth = [
  { m: 'Oct', users: 13614 },
  { m: 'Nov', users: 19400 },
  { m: 'Dec', users: 30372 },
  { m: 'Jan', users: 26510 },
  { m: 'Feb', users: 45668 },
];
const maxUsers = Math.max(...growth.map((g) => g.users));

const audienceRaw = [
  { flag: '🇺🇸', name: 'United States', users: 3911 },
  { flag: '🇬🇧', name: 'United Kingdom', users: 3118 },
  { flag: '🇦🇺', name: 'Australia', users: 1506 },
  { flag: '🇨🇦', name: 'Canada', users: 765 },
  { flag: '🇮🇪', name: 'Ireland', users: 148 },
  { flag: '🇳🇿', name: 'New Zealand', users: 113 },
];
const audienceTotal = audienceRaw.reduce((acc, a) => acc + a.users, 0);
const audience = audienceRaw.map((a) => ({
  ...a,
  pct: (a.users / audienceTotal) * 100,
}));
const maxPct = audience[0].pct;

const playerStats = [
  { big: '10,225', label: 'Players tracked globally', sub: 'Every competitive TOW player with a recorded result' },
  { big: '2,011', label: 'Signed-up accounts', sub: '914 have claimed a tracked player profile' },
  { big: '2.7×', label: 'Quarter-over-quarter signup growth', sub: 'Last 3 months vs the 3 before' },
];

const placements = [
  { title: 'Homepage Hero', desc: 'First impression. Leaderboard + hero-adjacent slot.', img: '/images/sponsor/homepage-hero.png' },
  { title: 'Regional Dashboard', desc: 'Geo-targeted. UK players see UK sponsors.', img: '/images/sponsor/dashboard.png' },
  { title: 'Army Lists', desc: '70k+ pageviews / month. Highest dwell-time.', img: '/images/sponsor/army-lists.png' },
  { title: 'Global Rankings', desc: 'The leaderboard everyone checks.', img: '/images/sponsor/global-rankings.png' },
];

const mobilePlacements = [
  { title: 'Mobile — Rankings', desc: '320×100 banner above the leaderboard.', img: '/images/sponsor/mobile-1.png' },
  { title: 'Mobile — Army Lists', desc: '320×100 banner above the list feed.', img: '/images/sponsor/mobile-2.png' },
];

const pricing = [
  {
    pkg: 'Regional — Tier 1',
    desc: 'Regional dashboard, rankings & tournament pages — pick UK or US',
    flags: ['🇬🇧', '🇺🇸'],
    reach: '~30%',
    price: '£50 / USD$60',
    unit: 'per region / mo',
    slots: '3 per region',
  },
  {
    pkg: 'Regional — Tier 2',
    desc: 'Regional dashboard, rankings & tournament pages — pick AU or CA',
    flags: ['🇦🇺', '🇨🇦'],
    reach: '~15%',
    price: 'AUD$50 / CAD$50',
    unit: 'per region / mo',
    slots: '3 per region',
  },
  {
    pkg: 'Regional — Tier 3',
    desc: 'Every other region — NZ, IE, EU, ZA, JP, and more',
    flags: ['🌐'],
    reach: '~50%',
    price: '£25 / USD$30',
    unit: 'per region / mo',
    slots: '3 per region',
  },
  {
    pkg: 'Global Spotlight',
    desc: 'oldworldrankings.com homepage + global rankings',
    flags: ['🌐'],
    reach: '~30%',
    price: '£100 / USD$130',
    unit: 'flat / mo',
    slots: '4 global',
  },
  {
    pkg: 'Army Lists Feature',
    desc: 'Inside every army-list detail modal, opened from any tournament page',
    flags: ['🌐'],
    reach: '~60%',
    price: '£150 / USD$190',
    unit: 'flat / mo',
    slots: '2 global',
  },
];

const trafficStats = [
  { big: '24,464', label: 'Google organic clicks' },
  { big: '256,486', label: 'Google impressions' },
  { big: '500k+', label: 'Real-human pageviews' },
  { big: '9.54%', label: 'Search CTR' },
];

const platformStats = [
  { big: '1,721', label: 'Tournaments tracked' },
  { big: '88,375', label: 'Games played' },
  { big: '25', label: 'Regions worldwide' },
];
---

<Layout
  title="OWR Sponsor Prospectus"
  description="Sponsor slots on Old World Rankings — reach the most engaged Warhammer: The Old World players on the web."
  noindex={true}
>
  <div id="deck">

    <!-- Top nav menu -->
    <header class="deck-header">
      <a href="/" class="deck-logo">
        <img src="/images/owr_logo_white.png" alt="OWR" />
      </a>
      <nav class="deck-menu" id="deck-menu">
        {slides.map((s, i) => (
          <button class="deck-menu-item" data-menu={i} aria-label={`Go to ${s.label}`}>
            <span class="deck-menu-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="deck-menu-label">{s.label}</span>
          </button>
        ))}
      </nav>
      <div class="deck-kicker">Sponsor Prospectus · 2026</div>
    </header>

    <!-- Slides track -->
    <div class="slides-track" id="slides-container">

      <!-- ============ 1. COVER ============ -->
      <section class="slide slide-cover" data-slide="0">
        <div class="slide-inner slide-inner-center">
          <img src="/images/owr_logo_white.png" alt="" class="cover-logo" />
          <div class="kicker-big">Sponsor Prospectus · 2026</div>
          <h1 class="title-xxl">
            Reach the most engaged
            <span class="gold">Warhammer: The Old World</span>
            players on the web.
          </h1>
          <p class="lead">
            The rankings, tournaments and army-list platform that serious TOW players use every week.
          </p>
          <div class="hint">
            <span>→ Use arrow keys, click the menu, or swipe</span>
          </div>
        </div>
      </section>

      <!-- ============ 2. PLATFORM ============ -->
      <section class="slide" data-slide="1">
        <div class="slide-inner">
          <div class="kicker">The platform</div>
          <h2 class="title-xl">
            Every competitive TOW event,
            <span class="gold">in one place.</span>
          </h2>
          <p class="lead-tight">
            Players find events, register, build lists, and see the meta.
            Organisers run events end-to-end.
          </p>

          <div class="stat-row-3">
            <a class="stat-card" href={`${APP_URL}/latest`} target="_blank" rel="noopener">
              <div class="stat-big">1,721</div>
              <div class="stat-label">Tournaments tracked →</div>
            </a>
            <a class="stat-card" href={`${APP_URL}/global_rankings`} target="_blank" rel="noopener">
              <div class="stat-big">88,375</div>
              <div class="stat-label">Games played →</div>
            </a>
            <a class="stat-card" href="/#regions" target="_blank" rel="noopener">
              <div class="stat-big">25</div>
              <div class="stat-label">Regions worldwide →</div>
            </a>
          </div>

          <div class="pillar-row">
            <a class="pillar" href={`${APP_URL}/global_rankings`} target="_blank" rel="noopener">
              <div class="pillar-icon"><Trophy size={22} strokeWidth={2} /></div>
              <div class="pillar-title gold">Rankings →</div>
              <div class="pillar-desc">Global and regional leaderboards. Player ratings that travel across every region.</div>
            </a>
            <a class="pillar" href={`${APP_URL}/faction_stats`} target="_blank" rel="noopener">
              <div class="pillar-icon"><BarChart size={22} strokeWidth={2} /></div>
              <div class="pillar-title gold">Faction Stats →</div>
              <div class="pillar-desc">Win rates, matchups and meta trends for every faction and subfaction.</div>
            </a>
            <a class="pillar" href={`${APP_URL}/upcoming`} target="_blank" rel="noopener">
              <div class="pillar-icon"><CalendarArrowUp size={22} strokeWidth={2} /></div>
              <div class="pillar-title gold">Upcoming Events →</div>
              <div class="pillar-desc">Event discovery, registration, live pairings, public venue display.</div>
            </a>
            <a class="pillar" href={`${APP_URL}/army_lists`} target="_blank" rel="noopener">
              <div class="pillar-icon"><ScrollText size={22} strokeWidth={2} /></div>
              <div class="pillar-title gold">Army Lists →</div>
              <div class="pillar-desc">Browse army lists from tournaments around the world. Highest-dwell page.</div>
            </a>
            <a class="pillar" href={`${APP_URL}/galleries`} target="_blank" rel="noopener">
              <div class="pillar-icon"><Image size={22} strokeWidth={2} /></div>
              <div class="pillar-title gold">Galleries →</div>
              <div class="pillar-desc">Painted army showcases. Tens of thousands of hobby pics.</div>
            </a>
            <a class="pillar" href={`${APP_URL}/builder`} target="_blank" rel="noopener">
              <div class="pillar-icon"><Hammer size={22} strokeWidth={2} /></div>
              <div class="pillar-title gold">Battle Builder →</div>
              <div class="pillar-desc">Build and manage your army lists with our native list builder.</div>
            </a>
          </div>
        </div>
      </section>

      <!-- ============ 3. TRAFFIC ============ -->
      <section class="slide" data-slide="2">
        <div class="slide-inner">
          <div class="kicker">Traffic · over 3 months</div>
          <h2 class="title-xl">
            <span class="gold">3.4× growth</span> in five months.
          </h2>
          <p class="lead-tight">
            Not a spike — a consistent upward slope as TOW takes share of the GW community.
          </p>

          <div class="traffic-split">
            <div class="stat-stack">
              {trafficStats.map((s) => (
                <div class="stat-row">
                  <span class="stat-row-big">{s.big}</span>
                  <span class="stat-row-label">{s.label}</span>
                </div>
              ))}
            </div>

            <div class="chart-wrap">
              <div class="chart-kicker">Monthly active users</div>
              <div class="chart-bars">
                {growth.map((g) => (
                  <div class="chart-col">
                    <div class="chart-val">{(g.users / 1000).toFixed(1)}k</div>
                    <div class="chart-bar" style={`height: ${(g.users / maxUsers) * 100}%`}></div>
                    <div class="chart-month">{g.m}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ============ 4. AUDIENCE ============ -->
      <section class="slide" data-slide="3">
        <div class="slide-inner">
          <div class="kicker">Players &amp; audience</div>
          <h2 class="title-xl">
            Real players. <span class="gold">Real growth.</span>
          </h2>

          <div class="player-stats">
            {playerStats.map((s) => (
              <div class="player-stat-card">
                <div class="player-stat-big">{s.big}</div>
                <div class="player-stat-label">{s.label}</div>
                <div class="player-stat-sub">{s.sub}</div>
              </div>
            ))}
          </div>

          <div class="audience-heading">
            <div class="kicker" style="margin-bottom: 0.5rem">Traffic share — top markets</div>
            <p class="audience-note">English-speaking, tournament-active hobbyists. US + UK + AU + CA carry the bulk of engagement.</p>
          </div>

          <div class="audience-list">
            {audience.map((a) => (
              <div class="audience-row">
                <span class="audience-flag">{a.flag}</span>
                <span class="audience-name">{a.name}</span>
                <div class="audience-bar-wrap">
                  <div class="audience-bar" style={`width: ${(a.pct / maxPct) * 100}%`}></div>
                </div>
                <span class="audience-val">{a.pct.toFixed(1)}%</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ============ 5. WHY NOW ============ -->
      <section class="slide" data-slide="4">
        <div class="slide-inner slide-inner-center">
          <div class="kicker-big">Why now</div>
          <h2 class="title-xxl">
            The Old World could be
            <span class="gold">the fastest-growing</span>
            Games Workshop system.
          </h2>
          <p class="lead">
            Trending to surpass Age of Sigmar as the <span class="white-bold">#2 GW game</span> by engaged-player base within 12 months.
            Low CPM today. Way more expensive tomorrow.
          </p>

          <div class="why-stats">
            <div class="why-stat"><div class="why-big">3.4×</div><div class="why-label">User growth in 5 months</div></div>
            <div class="why-stat"><div class="why-big">#1</div><div class="why-label">TOW rankings platform</div></div>
            <div class="why-stat"><div class="why-big">Low</div><div class="why-label">CPM today vs 12 months out</div></div>
          </div>
        </div>
      </section>

      <!-- ============ 6. PLACEMENTS ============ -->
      <section class="slide" data-slide="5">
        <div class="slide-inner">
          <div class="kicker">Placements</div>
          <h2 class="title-xl">
            Built for the <span class="gold">hobby.</span>
          </h2>
          <p class="lead-tight">
            Static image ads. Max 3 sponsors per slot per region. Served from our CDN.
            No third-party networks, no pop-ups, no retargeting.
            <span class="pro-note">* OWR Pro members get an ad-free experience — ads shown to free users only.</span>
          </p>

          <div class="placement-split">
            <div class="placement-grid">
              {placements.map((p) => (
                <div class="placement-card">
                  <button type="button" class="placement-img-wrap zoomable" data-zoom-src={p.img} data-zoom-caption={p.title}>
                    <img src={p.img} alt={p.title} loading="lazy" />
                    <span class="zoom-hint" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M11 8v6M8 11h6"/></svg>
                    </span>
                  </button>
                  <div class="placement-body">
                    <div class="placement-title gold">{p.title}</div>
                    <div class="placement-desc">{p.desc}</div>
                  </div>
                </div>
              ))}
            </div>
            <div class="mobile-col">
              <div class="mobile-kicker">On mobile too</div>
              <div class="mobile-grid">
                {mobilePlacements.map((p) => (
                  <div class="mobile-card">
                    <button type="button" class="mobile-img-wrap zoomable" data-zoom-src={p.img} data-zoom-caption={p.title}>
                      <img src={p.img} alt={p.title} loading="lazy" />
                    </button>
                    <div class="mobile-label">{p.title}</div>
                  </div>
                ))}
              </div>
              <div class="mobile-kicker" style="margin-top: 0.5rem">Army list detail · 728×90</div>
              <div class="dialog-card">
                <button type="button" class="dialog-img-wrap zoomable" data-zoom-src="/images/sponsor/armylist-dialog.png" data-zoom-caption="Army list detail modal">
                  <img src="/images/sponsor/armylist-dialog.png" alt="Army list detail modal" loading="lazy" />
                </button>
                <div class="dialog-label">Opens from every tournament page — highest-intent moment on the platform</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ============ 7. PRICING ============ -->
      <section class="slide" data-slide="6">
        <div class="slide-inner">
          <div class="kicker">Pricing · launch rates</div>
          <h2 class="title-xl">
            Launch pricing. <span class="gold">Locked for first-wave sponsors.</span>
          </h2>
          <p class="lead-tight">
            These are introductory rates to fill initial inventory. First-wave sponsors lock these prices for the life of the contract — future rates go up as traffic, sign-ups and retention data come in.
          </p>

          <div class="pricing-table">
            <div class="pricing-header">
              <div class="pricing-cell">Package</div>
              <div class="pricing-cell pricing-right">Reach*</div>
              <div class="pricing-cell pricing-right">Launch rate</div>
              <div class="pricing-cell pricing-right">Slots</div>
            </div>
            {pricing.map((row) => (
              <div class="pricing-row">
                <div class="pricing-cell pricing-pkg">
                  <div class="pricing-pkg-line">
                    <span class="pricing-flags">{row.flags.join(' ')}</span>
                    <span>{row.pkg}</span>
                  </div>
                  <div class="pricing-pkg-desc">{row.desc}</div>
                </div>
                <div class="pricing-cell pricing-right pricing-reach">{row.reach}</div>
                <div class="pricing-cell pricing-right pricing-price">
                  <div>{row.price}</div>
                  <div class="pricing-unit">{row.unit}</div>
                </div>
                <div class="pricing-cell pricing-right pricing-slots">{row.slots}</div>
              </div>
            ))}
          </div>
          <p class="pricing-foot">* Approximate share of real-human engaged sessions over the last 90 days. Regional tiers price <strong>per region</strong> — buy one or several within a tier.</p>

          <div class="discount-row">
            <div class="discount-card">
              <div class="discount-title gold">Bundle discount</div>
              <ul class="discount-list">
                <li>6 months upfront — <span class="gold">15% off</span></li>
                <li>12 months upfront — <span class="gold">20% off</span> + footer logo in event emails</li>
                <li>Affiliate link? Extra <span class="gold">15% off</span> any tier</li>
              </ul>
            </div>
            <div class="discount-card">
              <div class="discount-title gold">Included free</div>
              <ul class="discount-list">
                <li>Logo on public Sponsors page</li>
                <li>UTM tracking on every link out</li>
                <li>Creative help if you need it</li>
                <li>Launch in 1 business week</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- ============ 8. CLOSE ============ -->
      <section class="slide" data-slide="7">
        <div class="slide-inner slide-inner-center">
          <div class="kicker-big">Next step</div>
          <h2 class="title-xxl">Let's do this.</h2>
          <p class="lead">
            First-wave slots are filling — no hard-sell, just first-come, first-served.
            Pick the channel that suits you.
          </p>
          <div class="cta-row">
            <a href="mailto:sponsors@oldworldrankings.com?subject=OWR%20Sponsor%20Slot%20%E2%80%94%20Interested" class="cta-btn">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" /></svg>
              Email us
            </a>
            <button type="button" data-action="banshee-open" class="cta-btn cta-btn-outline">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z" /><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" /><path d="M12 17h.01" /></svg>
              Chat with us
            </button>
          </div>
          <div class="close-foot">
            <p>Old World Rankings · oldworldrankings.com</p>
            <p>The rankings, tournaments and army-list platform for Warhammer: The Old World.</p>
          </div>
        </div>
      </section>

    </div>

    <!-- Prev / Next -->
    <button id="prev-btn" class="nav-btn nav-prev" aria-label="Previous slide">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
    </button>
    <button id="next-btn" class="nav-btn nav-next" aria-label="Next slide">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
    </button>

    <!-- Counter / mobile next pill -->
    <button type="button" class="slide-counter" id="slide-counter" aria-label="Next slide">
      <span id="slide-counter-text">01 / 08</span>
      <span class="slide-counter-next" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
      </span>
    </button>

    <!-- Lightbox -->
    <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-hidden="true">
      <button id="lightbox-close" class="lightbox-close" aria-label="Close">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12" /></svg>
      </button>
      <img id="lightbox-img" class="lightbox-img" alt="" />
      <div id="lightbox-caption" class="lightbox-caption"></div>
    </div>
  </div>

  <script is:inline define:vars={{ total: slides.length }}>
    (function () {
      const container = document.getElementById('slides-container');
      const prevBtn = document.getElementById('prev-btn');
      const nextBtn = document.getElementById('next-btn');
      const menuItems = Array.from(document.querySelectorAll('[data-menu]'));
      const counter = document.getElementById('slide-counter');
      const counterText = document.getElementById('slide-counter-text');
      let current = 0;

      function pad2(n) { return String(n).padStart(2, '0'); }

      function isVertical() { return window.matchMedia('(max-width: 700px)').matches; }

      function go(idx) {
        current = Math.max(0, Math.min(total - 1, idx));
        if (isVertical()) {
          container.style.transform = `translateY(-${current * 100}vh)`;
        } else {
          container.style.transform = `translateX(-${current * 100}vw)`;
        }
        menuItems.forEach((m, i) => {
          m.classList.toggle('is-current', i === current);
        });
        counterText.textContent = `${pad2(current + 1)} / ${pad2(total)}`;
        prevBtn.disabled = current === 0;
        nextBtn.disabled = current === total - 1;
        counter.disabled = current === total - 1;
        if (history.replaceState) history.replaceState(null, '', `#${current + 1}`);
      }

      window.addEventListener('resize', () => go(current));

      prevBtn.addEventListener('click', () => go(current - 1));
      nextBtn.addEventListener('click', () => go(current + 1));
      counter.addEventListener('click', () => { if (current < total - 1) go(current + 1); });
      menuItems.forEach((m, i) => m.addEventListener('click', () => go(i)));

      document.addEventListener('keydown', (e) => {
        if (e.target.closest('input, textarea, [contenteditable]')) return;
        if (document.getElementById('lightbox').classList.contains('is-open')) return;
        if (e.key === 'ArrowRight' || e.key === 'PageDown' || e.key === ' ') { e.preventDefault(); go(current + 1); }
        else if (e.key === 'ArrowLeft' || e.key === 'PageUp') { e.preventDefault(); go(current - 1); }
        else if (e.key === 'Home') go(0);
        else if (e.key === 'End') go(total - 1);
        else if (/^[1-9]$/.test(e.key)) { const n = parseInt(e.key, 10) - 1; if (n < total) go(n); }
      });

      let touchStartX = null, touchStartY = null;
      container.addEventListener('touchstart', (e) => {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
      }, { passive: true });
      container.addEventListener('touchend', (e) => {
        if (touchStartX === null) return;
        const dx = e.changedTouches[0].clientX - touchStartX;
        const dy = e.changedTouches[0].clientY - touchStartY;
        const useY = isVertical();
        const primary = useY ? dy : dx;
        const cross = useY ? dx : dy;
        if (Math.abs(primary) > 60 && Math.abs(primary) > Math.abs(cross) * 1.2) {
          go(current + (primary < 0 ? 1 : -1));
        }
        touchStartX = null;
        touchStartY = null;
      }, { passive: true });

      const hashMatch = window.location.hash.match(/^#(\d+)$/);
      const initial = hashMatch ? parseInt(hashMatch[1], 10) - 1 : 0;
      go(initial >= 0 && initial < total ? initial : 0);

      // Banshee chat — trigger the same widget the main nav uses
      document.querySelectorAll('[data-action="banshee-open"]').forEach((el) => {
        el.addEventListener('click', (ev) => {
          ev.preventDefault();
          if (typeof window.banshee === 'function') {
            window.banshee('open');
          }
        });
      });

      // Lightbox
      const lb = document.getElementById('lightbox');
      const lbImg = document.getElementById('lightbox-img');
      const lbCaption = document.getElementById('lightbox-caption');
      const lbClose = document.getElementById('lightbox-close');
      function openLb(src, caption) {
        lbImg.src = src;
        lbCaption.textContent = caption || '';
        lb.classList.add('is-open');
        lb.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }
      function closeLb() {
        lb.classList.remove('is-open');
        lb.setAttribute('aria-hidden', 'true');
        lbImg.src = '';
        document.body.style.overflow = '';
      }
      document.querySelectorAll('.zoomable').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          openLb(btn.getAttribute('data-zoom-src'), btn.getAttribute('data-zoom-caption'));
        });
      });
      lbClose.addEventListener('click', closeLb);
      lb.addEventListener('click', (e) => { if (e.target === lb) closeLb(); });
      document.addEventListener('keydown', (e) => {
        if (lb.classList.contains('is-open') && e.key === 'Escape') { e.preventDefault(); closeLb(); }
      });
    })();
