---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getClient } from '../../lib/contentful';
import type { InsightArticleSkeleton } from '../../lib/contentful-types';
import { latestNewsletter, formatNewsletterDate } from '../../lib/newsletters';

const featuredNewsletter = await latestNewsletter();

const client = getClient();

let articles: import('../../lib/contentful-types').InsightArticleEntry[] = [];

if (client) {
  try {
    const response = await client.getEntries<InsightArticleSkeleton>({
      content_type: 'insightArticle',
      order: ['-fields.publishDate'],
      include: 2,
    });
    articles = response.items;
  } catch {
    // Content type may not exist yet — render empty state
  }
}
---

<Layout
  title="Insights | Old World Rankings"
  description="Data-driven analysis of competitive Warhammer: The Old World. Tournament trends, faction breakdowns, and meta insights."
>
  <Nav />

  <main class="bg-white dark:bg-[#0a0c10] pt-24 pb-16 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4">Insights & Articles</h1>
        <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
          Analysis, guides, and community stories to help grow the Old World.
        </p>
      </div>

      {featuredNewsletter && (
        <section class="mb-12">
          <div class="flex items-baseline justify-between mb-4">
            <h2 class="text-sm font-semibold tracking-widest uppercase text-owr-gold-dark dark:text-owr-gold">Latest Newsletter</h2>
            <a href="/newsletter" class="text-sm text-gray-500 dark:text-gray-400 hover:text-owr-gold-dark transition-colors">All issues &rarr;</a>
          </div>
          <a
            href={`/newsletter/${featuredNewsletter.slug}`}
            class="group flex flex-col sm:flex-row rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-white/[0.03] overflow-hidden hover:border-owr-gold/60 dark:hover:border-owr-gold/40 transition-colors"
          >
            <div class="relative sm:w-72 md:w-80 flex-shrink-0 aspect-[16/9] sm:aspect-auto overflow-hidden">
              <img
                src={featuredNewsletter.heroImage}
                alt={featuredNewsletter.title}
                class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
              />
            </div>
            <div class="p-4 sm:py-5 sm:px-6 flex flex-col justify-center min-w-0">
              <p class="text-xs text-gray-500 dark:text-gray-400 mb-2 uppercase tracking-wider font-medium">
                {formatNewsletterDate(featuredNewsletter.publishedAt)}
              </p>
              <h3 class="text-lg sm:text-xl font-bold text-gray-900 dark:text-white mb-2 group-hover:text-owr-gold-dark transition-colors">
                {featuredNewsletter.title}
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2">
                {featuredNewsletter.preheader}
              </p>
            </div>
          </a>
        </section>
      )}

      {articles.length > 0 ? (
        <div class="space-y-4">
          {articles.map((article) => {
            const image = article.fields.featuredImage
              && 'fields' in article.fields.featuredImage
              ? article.fields.featuredImage.fields?.file?.url
              : null;
            const tags = article.fields.tags || [];
            const date = new Date(article.fields.publishDate).toLocaleDateString('en-GB', {
              day: 'numeric', month: 'short', year: 'numeric',
            });
            const hasVideo = !!article.fields.youtubeUrl;
            const authorEntry = article.fields.authorRef && 'fields' in article.fields.authorRef
              ? article.fields.authorRef : null;
            const authorAvatar = authorEntry?.fields?.avatar && 'fields' in authorEntry.fields.avatar
              ? authorEntry.fields.avatar.fields?.file?.url : null;

            return (
              <a href={`/insights/${article.fields.slug}`}
                class="group flex flex-col sm:flex-row rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-white/[0.03] overflow-hidden hover:border-gray-400 dark:hover:border-gray-600 transition-colors">
                {image && (
                  <div class="relative sm:w-64 md:w-72 flex-shrink-0 aspect-[16/9] sm:aspect-auto overflow-hidden">
                    <img src={`https:${image}`} alt={article.fields.title}
                      class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300" />
                    {hasVideo && (
                      <div class="absolute inset-0 flex items-center justify-center">
                        <div class="w-10 h-10 rounded-full bg-black/60 flex items-center justify-center">
                          <svg class="w-4 h-4 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M8 5v14l11-7z" />
                          </svg>
                        </div>
                      </div>
                    )}
                  </div>
                )}
                <div class="p-4 sm:py-4 sm:px-5 flex flex-col justify-center min-w-0">
                  <div class="flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400 mb-1.5">
                    {authorEntry && (
                      <span class="flex items-center gap-1.5">
                        {authorAvatar && (
                          <img src={`https:${authorAvatar}`} alt="" class="w-6 h-6 rounded-full ring-1 ring-owr-gold/30" />
                        )}
                        <span class="text-gray-700 dark:text-gray-300">@{authorEntry.fields.nickname || authorEntry.fields.name}</span>
                        <span class="text-gray-300 dark:text-gray-600">&middot;</span>
                      </span>
                    )}
                    <time>{date}</time>
                    {article.fields.featured && (
                      <span class="rounded-full bg-owr-gold text-gray-900 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider">Featured</span>
                    )}
                  </div>
                  <h2 class="text-base font-bold text-gray-900 dark:text-white mb-1 group-hover:text-owr-gold transition-colors">
                    {article.fields.title}
                  </h2>
                  <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2 mb-2">
                    {article.fields.description}
                  </p>
                  {tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5">
                      {tags.slice(0, 4).map((tag: string) => (
                        <span class="text-[11px] px-2 py-0.5 rounded-full bg-gray-200 dark:bg-white/[0.06] text-gray-600 dark:text-gray-400">
                          {tag}
                        </span>
                      ))}
                      {tags.length > 4 && (
                        <span class="text-[11px] px-2 py-0.5 rounded-full bg-gray-200 dark:bg-white/[0.06] text-gray-500 dark:text-gray-500">
                          +{tags.length - 4}
                        </span>
                      )}
                    </div>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-gray-500 dark:text-gray-400">No insights published yet. Check back soon.</p>
        </div>
      )}
    </div>
  </main>
  <Footer />
</Layout>
